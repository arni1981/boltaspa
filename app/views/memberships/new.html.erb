<%= render 'layouts/shared/page_header',
    title: t('.title'),
    subtitle: t('.subtitle'),
    breadcrumbs: [{ name: t('common.home'), path: root_path }, { name: t('.breadcrumb_current') }] %>

<div class="max-w-2xl mx-auto py-12 px-6">
  <section class="bg-white border border-gray-100 rounded-[2.5rem] p-12 shadow-sm">

    <%= form_with url: join_league_path, class: "space-y-10" do |f| %>

      <%= render 'layouts/error_messages' %>

      <div>
        <%= f.label :invite_code, t('.code_label'),
            class: "block text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-4" %>

        <%= f.text_field :invite_code,
            placeholder: t('.code_placeholder'),
            class: "w-full px-8 py-6 bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-[#2d5a43] font-mono text-2xl font-black tracking-[0.1em] uppercase placeholder:text-gray-200 transition-all text-[#0a1d13]",
            autofocus: true %>

        <p class="mt-6 text-[11px] text-slate-400 font-medium leading-relaxed max-w-md">
          <%= t('.helper_text') %>
        </p>
      </div>

      <div class="pt-4">
        <%= f.button class: "w-full bg-[#2d5a43] text-white px-10 py-5 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-[#1e3f2e] transition-all active:scale-95 flex items-center justify-center gap-4 shadow-xl shadow-[#2d5a43]/10" do %>
          <span><%= t('.submit_button') %></span>
          <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        <% end %>
      </div>
    <% end %>

  </section>
</div>
