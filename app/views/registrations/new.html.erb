<%# app/views/registrations/new.html.erb %>

<%= render 'layouts/shared/page_header',
    title: t('.title'),
    breadcrumbs: [{ name: t('common.home'), path: root_path }, { name: t('.breadcrumb_current') }] %>

<div class="max-w-2xl mx-auto pb-32 px-6 space-y-8">

  <%# 1. THIRD-PARTY ENTRY: Google OAuth Card %>
  <section class="bg-white border border-gray-100 rounded-[2.5rem] shadow-sm overflow-hidden p-2">
    <%= button_to '/auth/google_oauth2', 
        data: { turbo: false },
        class: "w-full flex items-center justify-between bg-slate-50 hover:bg-slate-100 px-8 py-6 rounded-[2.2rem] group transition-all cursor-pointer" do %>
      <div class="flex items-center gap-6 pointer-events-none">
        <%= google_svg %>
        <div class="flex flex-col text-left">
          <span class="text-[11px] font-black text-[#0a1d13] uppercase tracking-widest leading-none mb-1">
            <%= t('.google_button_title', default: 'Skráning með Google') %>
          </span>
        </div>
      </div>
      <div class="bg-white p-3 rounded-xl shadow-sm group-hover:bg-[#2d5a43] group-hover:text-white transition-all shrink-0 pointer-events-none">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </div>
    <% end %>
  </section>

  <%# SEPARATOR %>
  <div class="flex items-center gap-4 px-10">
    <div class="h-px bg-gray-100 flex-1"></div>
    <span class="text-[9px] font-black text-slate-300 uppercase tracking-[0.4em]">
      <%= t('.or_separator', default: 'EÐA') %>
    </span>
    <div class="h-px bg-gray-100 flex-1"></div>
  </div>

  <%# 2. MANUAL ENTRY: Your original form %>
  <%= form_with model: @user, url: sign_up_path, class: "space-y-8" do |f| %>

    <%= render 'layouts/error_messages' %>

    <section class="bg-white border border-gray-100 rounded-[2.5rem] shadow-sm overflow-hidden">
      <header class="px-10 py-6 border-b border-gray-50 bg-gray-50/30">
        <h2 class="text-[10px] font-black text-[#0a1d13] uppercase tracking-[0.3em]"><%= t('.section_title') %></h2>
      </header>

      <div class="p-10 space-y-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <%= f.label :name, t('.name_label'), class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3" %>
            <%= f.text_field :name, 
                placeholder: t('.name_placeholder'),
                class: "w-full bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-[#2d5a43] text-[15px] font-bold text-[#0a1d13] px-6 py-4 transition-all placeholder:text-slate-300" %>
          </div>

          <div>
            <%= f.label :email_address, t('.email_label'), class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3" %>
            <%= f.email_field :email_address, 
                placeholder: t('.email_placeholder'),
                class: "w-full bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-[#2d5a43] text-[15px] font-bold text-[#0a1d13] px-6 py-4 transition-all placeholder:text-slate-300" %>
          </div>
        </div>

        <div>
          <%= f.label :password, t('.password_label'), class: "block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3" %>
          <%= f.password_field :password, 
              class: "w-full bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-[#2d5a43] text-[15px] font-bold text-[#0a1d13] px-6 py-4 transition-all" %>
        </div>

      <!--
        <div class="pt-10 border-t border-gray-50">
          <%= f.label :invite_code, t('.invite_code_label'), class: "block text-[10px] font-black text-sky-500 uppercase tracking-widest mb-4" %>
          <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="flex-1 w-full">
              <%= f.text_field :invite_code, 
                  value: params[:invite_code],
                  placeholder: t('.invite_code_placeholder'),
                  class: "w-full bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-[#2d5a43] text-xl font-mono font-black text-[#0a1d13] px-6 py-4 transition-all uppercase placeholder:text-slate-200" %>
            </div>

            <div class="w-full md:w-48 text-[11px] text-slate-400 leading-relaxed font-bold uppercase tracking-tight">
              <%= t('.invite_code_helper') %>
            </div>
          </div>
        </div> -->
      </div>
    </section>

    <div class="flex flex-col md:flex-row items-center justify-between gap-6 pt-4">
      <%= link_to t('.signin_text'), new_session_path, 
          class: "text-[10px] font-black text-sky-500 uppercase tracking-widest hover:text-sky-600 transition-colors" %>

      <%= f.button class: "w-full md:w-auto bg-[#2d5a43] text-white px-10 py-5 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-[#1e3f2e] transition-all shadow-xl shadow-[#2d5a43]/10 active:scale-95 flex items-center justify-center gap-3 cursor-pointer" do %>
        <span><%= t('.submit_button') %></span>
        <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      <% end %>
    </div>
  <% end %>
</div>
