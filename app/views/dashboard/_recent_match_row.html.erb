<%# app/views/dashboards/_recent_match_row.html.erb %>
<%# locals: (match:, predictions_map:) %>

<% my_pred = predictions_map[match.id]
my_pts = my_pred&.points_won.to_i
my_style = performance_tier(my_pts) %>

<%= turbo_stream_from match %>

<%# FIXED: Dropped 'bg-white' and 'border-b' utilities since the outer rounded list card manages containment lines %>
<div
  id="<%= dom_id(match) %>"
  class="
    flex flex-col md:grid md:grid-cols-12 md:items-center px-4 md:px-8 py-4.5 hover:bg-[#f9faf9] transition-all duration-300
    select-none
  "
>

  <%# 1. DESKTOP LEFT TRACK: Kickoff Time / Status Indicator %>
  <div class="hidden md:flex md:col-span-2">
    <div class="text-[12px] font-mono font-bold">
      <% if match.live? %>
        <div class="flex items-center gap-1.5 text-sky-500 animate-pulse">
          <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>
          <span class="text-[9px] tracking-wider font-bold uppercase"><%= t(".live") %></span>
        </div>
      <% else %>
        <div class="<%= match.finished? ? 'text-slate-300' : 'text-[#0a1d13]' %>">
          <%= match.finished? ? "FT" : l(match.kickoff_at, format: "%H:%M") %>
        </div>
      <% end %>
    </div>
  </div>

  <%# 2. MOBILE TOP TRACK: Time, Live Score Badge, and Prediction Tracker Pinned to Right %>
  <div class="flex items-center justify-between md:hidden mb-3.5">
    <div class="flex items-center gap-3">
      <div class="text-[11px] font-mono font-bold shrink-0">
        <% if match.live? %>
          <span class="text-sky-500 tracking-wider animate-pulse"><%= t(".live") %></span>
        <% else %>
          <span class="<%= match.finished? ? 'text-slate-300' : 'text-[#0a1d13]' %>">
            <%= match.finished? ? "FT" : l(match.kickoff_at, format: "%H:%M") %>
          </span>
        <% end %>
      </div>

      <div
        class="
          flex items-center gap-2 px-2.5 py-1 bg-[#f9faf9] border <%= match.live? ? 'border-sky-200' : 'border-slate-100' %> rounded-lg font-mono
          text-[13px] font-bold text-[#0a1d13]
        "
      >
        <span><%= match.started? ? match.home_score : "-" %></span>
        <span class="<%= match.live? ? 'text-sky-400' : 'text-slate-200' %>">:</span>
        <span><%= match.started? ? match.away_score : "-" %></span>
      </div>
    </div>

    <div class="flex items-center gap-2 shrink-0">
      <div class="flex flex-col items-end gap-0.5 pr-1">
        <span class="text-[7px] font-bold text-slate-400 uppercase tracking-widest"><%= t(".your_guess", default: "Spá") %></span>
        <span class="text-[11px] font-mono font-bold text-slate-600">
          <%= my_pred ? "#{my_pred.home_guess} - #{my_pred.away_guess}" : "—" %>
        </span>
      </div>

      <div
        class="
          h-8 min-w-10 px-2 rounded-lg flex items-center justify-center font-mono font-bold text-[12px] border
          <%= my_style[0] %> <%= my_style[1] %> <%= my_style[2] %>
        "
      >
        +<%= my_pts %>
      </div>
    </div>
  </div>

  <%# 3. CENTER TRACK: Desktop and Mobile Responsive Team Names Matrix %>
  <div class="flex-1 md:col-span-7 flex items-center justify-between md:justify-center min-w-0 md:px-4 mb-1 md:mb-0">
    <div class="flex-1 flex items-center justify-start md:justify-end gap-3 min-w-0">
      <span class="md:hidden text-[13px] font-bold text-[#0a1d13] truncate"><%= localized_tla(match.home_team) %></span>
      <span class="hidden md:block text-sm font-bold text-[#0a1d13] truncate"><%= localized_short_name(match.home_team) %></span>
      <div class="w-6 h-6 md:w-7 md:h-7 shrink-0">
        <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" %>
      </div>
    </div>

    <div
      class="
        hidden md:flex mx-6 items-center gap-3 px-4 py-1.5 bg-[#f9faf9] border border-slate-100 rounded-xl font-mono text-xl
        font-bold text-[#0a1d13] shrink-0
      "
    >
      <span class="w-4 text-center"><%= match.started? ? match.home_score : "-" %></span>
      <span class="text-slate-200">:</span>
      <span class="w-4 text-center"><%= match.started? ? match.away_score : "-" %></span>
    </div>

    <div class="flex-1 flex items-center justify-end md:justify-start gap-3 min-w-0">
      <div class="w-6 h-6 md:w-7 md:h-7 shrink-0">
        <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" %>
      </div>
      <span class="md:hidden text-[13px] font-bold text-[#0a1d13] truncate text-right"><%= localized_tla(match.away_team) %></span>
      <span class="hidden md:block text-sm font-bold text-[#0a1d13] truncate"><%= localized_short_name(match.away_team) %></span>
    </div>
  </div>

  <%# 4. RIGHT TRACK: Clean Single-User Prediction and Score Matrix Panel %>
  <div class="hidden md:flex md:col-span-3 shrink-0 items-center justify-end">
    <div class="flex items-center gap-5">
      <div class="flex flex-col items-end gap-0.5">
        <span class="text-[8px] font-bold text-slate-400 uppercase tracking-wider leading-none"><%= t(".your_guess", default: "Þín spá") %></span>
        <span class="text-sm font-mono font-bold text-slate-500 mt-0.5">
          <%= my_pred ? "#{my_pred.home_guess} - #{my_pred.away_guess}" : "—" %>
        </span>
      </div>

      <div
        class="
          h-11 w-16 rounded-xl flex items-center justify-center font-mono font-bold text-lg border transition-all tabular-nums
          <%= my_style[0] %> <%= my_style[1] %> <%= my_style[2] %>
        "
      >
        +<%= my_pts %>
      </div>
    </div>
  </div>

</div>
