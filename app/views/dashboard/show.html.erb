<header class="bg-[#0a1d13] rounded-[2.5rem] p-8 mb-10 text-white shadow-xl flex items-center justify-between relative overflow-hidden">
  <div class="relative z-10">
    <span class="text-[9px] font-black text-emerald-400 uppercase tracking-[0.4em] block mb-1">
      <%= t('.greeting_badge') %>
    </span>
    <h1 class="text-3xl font-black tracking-tighter uppercase">
      <%= t('.greeting_text', name: Current.user.name) %>
    </h1>
  </div>

  <div class="absolute -right-10 -top-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl"></div>
</header>

<div class="max-w-4xl mx-auto space-y-12 mb-40">

  <% @leagues.each do |league| %>
    <section class="space-y-4">
      <div class="flex items-center justify-between px-6">
        <div class="flex items-center gap-3">
          <div class="w-2 h-2 rounded-full bg-[#2d5a43]"></div>
          <h2 class="text-[11px] font-black text-slate-400 uppercase tracking-[0.3em]">
            <%= league.name %>
          </h2>
        </div>
        <span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">
          <%= t('.members_count', count: league.members.count) %>
        </span>
      </div>

      <div class="bg-white border border-gray-100 rounded-[2.5rem] shadow-sm overflow-hidden">
        <div class="divide-y divide-gray-50">
          <% league.league_competitions.each do |lc| %>
            <% standing = lc.standings.find_by(user_id: Current.user.id) %>

            <%= link_to league_competition_by_year_path(league, lc.competition, year: lc.year), class: "group flex items-center justify-between px-10 py-8 hover:bg-gray-50 transition-all" do %>

              <div class="flex items-center gap-6">
                <div class="w-12 h-12 bg-white rounded-2xl border border-gray-100 p-2.5 shadow-sm group-hover:border-emerald-200 transition-colors">
                  <%= image_tag lc.competition.emblem, class: "w-full h-full object-contain", alt: "#{lc.competition.name} emblem" %>
                </div>
                <div>
                  <span class="text-[15px] font-black text-[#0a1d13] uppercase tracking-tight block group-hover:text-[#2d5a43]">
                    <%= lc.competition.name %>
                  </span>
                  <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.1em]">
                    <%= t('.season_label') %> <%= lc.year %>
                  </p>
                </div>
              </div>

              <div class="flex items-center gap-16">
                <div class="text-right">
                  <div class="flex items-baseline justify-end gap-1.5">
                    <span class="text-2xl font-mono font-black text-[#0a1d13]">#<%= standing&.rank || '-' %></span>
                    <% if standing&.is_tied %>
                      <span class="text-[10px] font-black text-slate-300">=</span>
                    <% end %>
                  </div>
                  <span class="text-[9px] font-black text-emerald-500 uppercase tracking-widest">
                    <% if standing&.rank %>
                      <%= t('.percentile_label', percentage: (standing.rank.to_f / league.members.count * 100).round) %>
                    <% end %>
                  </span>
                </div>

                <div class="text-right min-w-[100px]">
                  <span class="text-2xl font-mono font-black text-[#2d5a43] block leading-none">
                    <%= standing&.total_points || 0 %>
                  </span>
                  <span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest"><%= t('.points_label') %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</div>

<div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-4rem)] max-w-md">
  <div class="bg-[#0a1d13] rounded-2xl p-2 shadow-2xl border border-white/10 flex items-center justify-between pl-6">
    <div class="min-w-0">
      <span class="text-[7px] font-black text-emerald-400 uppercase tracking-[0.2em] block"><%= t('.next_prediction_label') %></span>
      <p class="text-[11px] font-black text-white uppercase truncate pr-4">
        <%= @next_match ? @next_match.short_name_string : t('.no_matches_label') %>
      </p>
    </div>

    <%= link_to predictions_path, class: "bg-[#2d5a43] text-white px-8 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest active:scale-95 transition-all shadow-lg" do %>
      <%= t('.open_slip_button') %>
    <% end %>
  </div>
</div>
