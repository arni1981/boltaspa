<header
  class="
    bg-[#0a1d13] rounded-[2rem] p-6 md:p-8 mb-6 md:mb-8 text-white shadow-sm flex items-center justify-between relative
    overflow-hidden
  "
>
  <div class="relative z-10">
    <span class="text-[8px] md:text-[9px] font-mono font-bold text-emerald-400/90 uppercase tracking-[0.25em] block mb-1.5">
      <%= t(".greeting_badge") %>
    </span>

    <h1 class="text-xl md:text-2xl font-bold tracking-tight text-white">
      <%= t(".greeting_text", name: Current.user.name) %>
    </h1>
  </div>

  <div
    class="
      absolute -right-10 -top-10 w-32 h-32 md:w-40 md:h-40 bg-[#2d5a43]/20 rounded-full blur-2xl pointer-events-none
    "
  ></div>
</header>

<%# 1. FIXED CONTEXT WRAPPER: Matches the exact structure of your league headers %>
<% if @recent_results&.any? %>
  <section class="max-w-4xl mx-auto space-y-2 md:space-y-3 mb-6 md:mb-10 px-1">

    <%# Section Header Context Layer %>
    <div class="flex items-center justify-between px-4">
      <div class="flex items-center gap-2 md:gap-3">
        <div class="w-1 h-3.5 bg-[#2d5a43] rounded-full"></div>
        <h2 class="text-[10px] md:text-[11px] font-bold text-slate-400 uppercase tracking-[0.2em]">
          <%= t(".recent_results_title", default: "Nýjustu úrslit") %>
        </h2>
      </div>
      <span class="text-[9px] font-mono font-bold text-slate-300 uppercase tracking-wider">
        <%= t(".quick_view_label", default: "Yfirlit") %>
      </span>
    </div>

    <%# Rounded Card Container matching league layouts exactly %>
    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden divide-y divide-slate-50">
      <%= render partial: "recent_match_row",
      collection: @recent_results,
      as: :match,
      locals: {
        predictions_map: @predictions_map,
      } %>
    </div>
  </section>
<% end %>

<%# 2. MASTER LEAGUES TRACK GRID %>
<div class="max-w-4xl mx-auto space-y-6 md:space-y-10 mb-24 px-1">
  <% @leagues.each do |league| %>
    <section class="space-y-2 md:space-y-3">

      <%# Section Header Context Layer %>
      <div class="flex items-center justify-between px-4">
        <div class="flex items-center gap-2 md:gap-3">
          <div class="w-1 h-3.5 bg-[#2d5a43] rounded-full"></div>
          <h2 class="text-[10px] md:text-[11px] font-bold text-slate-400 uppercase tracking-[0.2em]">
            <%= league.name %>
          </h2>
        </div>
        <span class="text-[9px] font-mono font-bold text-slate-300 uppercase tracking-wider">
          <%= t(".members_count", count: league.members.size, default: "#{league.members.size} keppendur") %>
        </span>
      </div>

      <%# Competition Rows Grid %>
      <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
        <div class="divide-y divide-slate-50">
          <% league.league_competitions.each do |lc| %>
            <% standing = lc.standings.find_by(user_id: Current.user.id) %>

            <%= link_to league_competition_by_year_path(league, lc.competition, year: lc.year), 
                class: "group flex items-center justify-between px-4 md:px-8 py-4 md:py-6 hover:bg-[#f9faf9] transition-all" do %>

              <div class="flex items-center gap-3 md:gap-5 min-w-0">
                <div
                  class="
                    w-10 h-10 md:w-12 md:h-12 bg-white rounded-xl border border-slate-100 p-2 md:p-2.5 shadow-sm
                    group-hover:border-[#2d5a43]/30 shrink-0 transition-colors flex items-center justify-center
                  "
                >
                  <%= image_tag lc.competition.emblem,
                  class:
                    "w-full h-full object-contain grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all",
                  alt: lc.competition.localized_name %>
                </div>

                <div class="min-w-0">
                  <span class="text-[13px] md:text-[16px] font-bold text-[#0a1d13] block tracking-tight truncate">
                    <%= lc.competition.localized_name(with_year: false) %>
                  </span>
                  <span class="text-[9px] md:text-[10px] font-mono font-bold text-slate-400 uppercase tracking-wider block mt-0.5">
                    <%= t(".season_label", year: lc.year, default: "Tímabilið #{lc.year}") %>
                  </span>
                </div>
              </div>

              <%# Numeric Stats Columns Matrix %>
              <div class="flex items-center gap-6 md:gap-12 shrink-0">

                <%# Rank Alignment Column %>
                <div class="text-right min-w-[45px] md:min-w-[60px]">
                  <span
                    class="
                      text-[16px] md:text-[22px] font-mono font-bold text-[#0a1d13] tracking-tight tabular-nums block leading-none
                    "
                  >
                    <%= (standing&.total_points&.positive?) ? "##{standing.rank}" : "—" %>
                  </span>
                  <span class="text-[8px] md:text-[9px] font-bold text-slate-400 uppercase tracking-wider block mt-1">
                    <%= (standing&.total_points&.positive?) ? "af #{league.members.size}" : t(".not_started") %>
                  </span>
                </div>

                <%# Points Total Column %>
                <div class="text-right min-w-[50px] md:min-w-[70px]">
                  <span
                    class="
                      text-[16px] md:text-[22px] font-mono font-bold text-[#2d5a43] tracking-tight tabular-nums block leading-none
                    "
                  >
                    <%= standing&.total_points || 0 %>
                  </span>
                  <span class="text-[8px] md:text-[9px] font-bold text-slate-300 uppercase tracking-wider block mt-1">
                    <%= t(".points_label", default: "stig") %>
                  </span>
                </div>

              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</div>

<%# 3. FIXED FLOATING ACTION SLIP DECK AS PRIMARY BAR %>
<% if @next_match %>
  <div class=" fixed bottom-5 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] md:w-[calc(100%-4rem)] max-w-md ">
    <div
      class="
        bg-[#0a1d13]/95 backdrop-blur-lg rounded-2xl p-2 shadow-2xl border border-white/10 flex items-center justify-between
        pl-4 md:pl-5
      "
    >
      <div class="min-w-0 pr-2">
        <span class="text-[8px] font-mono font-bold text-emerald-400 uppercase tracking-widest block mb-0.5">
          <%= t(".next_prediction_label") %>
        </span>
        <p class="text-[11px] font-bold text-white uppercase tracking-tight truncate">
          <%= localized_short_name(@next_match.home_team) %>
          -
          <%= localized_short_name(@next_match.away_team) %>
        </p>
      </div>

      <%= link_to predictions_path, class: "bg-[#2d5a43] hover:bg-[#34684e] text-white px-6 md:px-8 py-3 rounded-xl text-[10px] font-bold uppercase tracking-wider active:scale-95 transition-all shrink-0 flex items-center shadow-sm" do %>
        <%= t(".open_slip_button") %>
      <% end %>
    </div>
  </div>
<% end %>
