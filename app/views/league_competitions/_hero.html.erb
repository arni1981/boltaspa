<%# locals: (league_competition:, current_user:) %>
<% league = league_competition.league
standings = league_competition.standings %>

<section
  class="
    mb-6 bg-[#0a1d13] rounded-2xl border border-white/5 shadow-md overflow-hidden px-6 md:px-8 py-4 flex
    items-center justify-between
  "
>

  <%# Combined Left Group: Everything reads naturally left-to-right from a single starting point %>
  <div class="flex items-center gap-6 overflow-x-auto no-scrollbar w-full md:w-auto">

    <%# 1. Personal Position Anchor %>
    <% my_rank_item = standings.find { |r| r.user == current_user } %>
    <% if my_rank_item %>
      <div
        class="
          bg-[#2d5a43] rounded-xl px-3.5 py-1.5 flex items-center gap-2.5 border border-white/5 shrink-0
        "
      >
        <span class="text-[12px] font-mono font-black text-white"><%= my_rank_item.rank %>.</span>
        <span class="text-[9px] font-black text-white uppercase tracking-wider"><%= t(".your_position") %></span>
        <span class="text-[12px] font-mono font-black text-white bg-black/10 px-1.5 py-0.5 rounded ml-0.5">
          <%= my_rank_item.total_points %><span class="text-[7px] font-normal text-white/50 ml-0.5"><%= t(".points_abbr") %></span>
        </span>
      </div>
    <% end %>

    <%# Clean vertical structural divider %>
    <div class="hidden md:block w-px h-5 bg-white/10 shrink-0"></div>

    <%# 2. Top 3 Loop (Sitting immediately adjacent to the personal rank) %>
    <div class="flex items-center gap-4 shrink-0">
      <% standings.first(3).each_with_index do |rank_item, i| %>
        <% is_me = rank_item.user == current_user %>

        <div
          class="
            flex items-center gap-2 text-[12px] tracking-tight <%= is_me ? 'bg-white/5 px-2.5 py-1 rounded-lg border border-white/5' : '' %>
          "
        >
          <span class="font-mono font-black text-[#2d5a43]"><%= i + 1 %>.</span>
          <span class="font-bold text-white/90 uppercase"><%= rank_item.user.name %></span>
          <span class="font-mono font-black text-white/60 text-[11px]"><%= rank_item.total_points %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%# 3. FIXED THE RIGHT SIDE: Premium, low-noise anchor link to the full leaderboard %>
  <div class="hidden md:block shrink-0">
    <%= link_to league_competition_by_year_leaderboard_path(league_slug: league.slug, competition_code: league_competition.competition.code,year:  league_competition.season.year), 
                class: "flex items-center gap-1.5 text-[9px] font-black text-white/40 uppercase tracking-widest hover:text-white transition-colors group" do %>
      <span><%= t(".full_leaderboard", default: "Heildarstaða") %></span>
      <svg
        class="w-3 h-3 transform group-hover:translate-x-0.5 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        stroke-width="3"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    <% end %>
  </div>

</section>
