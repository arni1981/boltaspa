<%= render 'layouts/shared/page_header', 
    title: @league_competition.competition.name, 
    subtitle: t('.subtitle_template', year: @league_competition.year, matchday: @current_matchday),
    breadcrumbs: [ 
      { name: @league.name, path: league_path(@league) },
      { name: t('.your_standing_badge'), path: nil }
    ] %>

<div class="max-w-5xl mx-auto space-y-12 pb-32 px-6">

  <section class="relative">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-1 bg-[#0a1d13] rounded-[2.5rem] overflow-hidden shadow-2xl shadow-[#0a1d13]/20 border border-white/5">
      <% @leaderboard.first(3).each_with_index do |rank_item, i| %>
        <% is_me = rank_item.user == Current.user %>
        <div class="p-10 flex flex-col items-center justify-center group relative border-r border-white/5 last:border-0 <%= is_me ? 'bg-white/5' : '' %>">
          <span class="text-[10px] font-black text-emerald-400/50 uppercase tracking-[0.4em] mb-3">
            <%= (i + 1).to_s + t('.position_suffix') %>
          </span>
          <span class="text-[15px] font-black text-white uppercase tracking-tight truncate w-full text-center px-4">
            <%= rank_item.user.name %>
          </span>
          <div class="mt-3 flex items-baseline gap-2">
            <span class="text-3xl font-mono font-black text-white tracking-tighter">
              <%= rank_item.total_points %>
            </span>
            <span class="text-[10px] font-bold text-white/20 uppercase tracking-widest"><%= t('.points_label') %></span>
          </div>

          <% if is_me %>
            <div class="absolute top-4 right-4">
              <div class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_#10b981]"></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <% my_rank_item = @leaderboard.find { |r| r.user == Current.user } %>
    <% if my_rank_item && my_rank_item.rank > 3 %>
      <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-full max-w-xs">
        <div class="bg-[#2d5a43] border border-white/10 rounded-2xl px-6 py-3 shadow-xl flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="text-[10px] font-mono font-black text-white/40"><%= my_rank_item.rank %>.</span>
            <span class="text-[11px] font-black text-white uppercase tracking-wider"><%= t('.your_position_label') %></span>
          </div>
          <div class="flex items-baseline gap-1">
            <span class="text-lg font-mono font-black text-white"><%= my_rank_item.total_points %></span>
            <span class="text-[8px] font-bold text-white/40 uppercase"><%= t('.points_label') %></span>
          </div>
        </div>
      </div>
    <% end %>
  </section>

  <%= render 'matchday_ticker', 
    league_competition: @league_competition,
    current_matchday: @current_matchday,
    league: @league,
    compare_user: @compare_user,
    predictions_map: @predictions_map,
    compare_predictions_map: @compare_predictions_map,
    matches: @matches
  %>

  <section class="bg-white border border-gray-100 rounded-[3rem] shadow-sm overflow-hidden">
    <header class="px-10 py-8 bg-gray-50/50 border-b border-gray-100 flex items-center justify-between">
      <div class="flex flex-col gap-1">
        <h2 class="text-[11px] font-black text-[#0a1d13] uppercase tracking-[0.4em]"><%= t('.leaderboard_title') %></h2>
        <p class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em]"><%= t('.leaderboard_note') %></p>
      </div>
    </header>

    <div class="overflow-x-auto">
      <table class="w-full border-separate border-spacing-0">
        <thead>
          <tr class="text-left">
            <th class="pl-12 py-6 text-[9px] font-black text-slate-300 uppercase tracking-widest w-24"><%= t('.table_header_rank') %></th>
            <th class="py-6 text-[9px] font-black text-slate-300 uppercase tracking-widest"><%= t('.table_header_competitor') %></th>
            <th class="py-6 text-center text-[9px] font-black text-slate-300 uppercase tracking-widest"><%= t('.table_header_form') %></th>
            <th class="py-6 text-center text-[9px] font-black text-slate-300 uppercase tracking-widest"><%= t('.table_header_3pt') %></th>
            <th class="pr-12 py-6 text-right text-[9px] font-black text-slate-300 uppercase tracking-widest"><%= t('.table_header_points') %></th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-50">
          <% @leaderboard.each do |rank_item| %>
            <% is_me = rank_item.user == Current.user %>
            <tr class="group hover:bg-emerald-50/30 transition-all relative <%= is_me ? 'bg-emerald-50/20' : '' %>">
              <td class="py-8 pl-12">
                <span class="text-xl font-mono font-black <%= is_me ? 'text-[#2d5a43]' : 'text-slate-300 group-hover:text-[#0a1d13]' %>">
                  <%= rank_item.rank %>
                </span>
              </td>

              <td class="py-8">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-xl bg-[#0a1d13] flex items-center justify-center text-white font-black text-[10px] shadow-sm">
                    <%= rank_item.user.name.first(2).upcase %>
                  </div>
                  <div class="flex flex-col">
                    <span class="text-[14px] font-black text-[#0a1d13] uppercase tracking-tight"><%= rank_item.user.name %></span>
                    <% if is_me %>
                      <span class="text-[8px] font-black text-emerald-600 uppercase tracking-[0.2em]"><%= t('.your_standing_badge') %></span>
                    <% end %>
                  </div>
                </div>
              </td>

              <td class="py-8">
                <div class="flex items-center justify-center gap-1.5">
                  <% form_data = rank_item.recent_form %>
                  <% form_data.each_with_index do |pts, index| %>
                    <% is_latest = (index == form_data.size - 1) %>
                    <div class="relative">
                      <div class="px-2.5 py-1.5 min-w-[36px] rounded-lg flex items-center justify-center text-[13px] font-mono font-black transition-all
                        <%= is_latest ? 'bg-[#0a1d13] text-white shadow-lg scale-110 z-10' : 'bg-slate-100 text-[#0a1d13]/80' %>">
                        <span class="<%= is_latest ? '' : (pts >= 15 ? 'text-emerald-600' : (pts < 5 ? 'text-rose-600' : '')) %>">
                          <%= pts %>
                        </span>
                      </div>
                      <% if is_latest %>
                        <span class="absolute -top-4 left-1/2 -translate-x-1/2 text-[7px] font-black text-[#0a1d13] uppercase tracking-[0.2em] whitespace-nowrap"><%= t('.latest_label') %></span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </td>

              <td class="py-8 text-center">
                <span class="text-[13px] font-mono font-bold text-slate-400 group-hover:text-[#0a1d13]">
                  <%= rank_item.exact_scores %>
                </span>
              </td>

              <td class="py-8 pr-12 text-right">
                <span class="text-3xl font-mono font-black tracking-tighter <%= is_me ? 'text-[#2d5a43]' : 'text-[#0a1d13]' %>">
                  <%= number_with_delimiter(rank_item.total_points) %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
