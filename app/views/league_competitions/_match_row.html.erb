<%# locals: (match:, predictions_map:, compare_predictions_map: nil, compare_user: nil) %>

<% my_pred = predictions_map[match.id]
comp_pred = compare_predictions_map&.[](match.id) if compare_user

my_pts = my_pred&.points_won.to_i
comp_pts = comp_pred&.points_won.to_i

my_style = performance_tier(my_pts)
comp_style = performance_tier(comp_pts) %>

<%= turbo_stream_from match %>

<div
  id="<%= dom_id(match) %>"
  class="
    flex flex-col md:grid md:grid-cols-12 md:items-center px-4 md:px-8 py-4.5 border-b border-slate-100
    bg-white hover:bg-[#f9faf9] transition-all duration-300
  "
>

  <%# 1. DESKTOP LEFT TRACK: Kickoff Time / Status Indicator (Col-span 1) %>
  <div class="hidden md:flex md:col-span-1">
    <div class="text-[12px] font-mono font-bold">
      <% if match.live? %>
        <div class="flex items-center gap-1.5 text-sky-500 animate-pulse">
          <span class="w-1.5 h-1.5 rounded-full bg-sky-500"></span>
          <span class="text-[9px] tracking-wider font-black uppercase"><%= t(".live") %></span>
        </div>
      <% else %>
        <div class="<%= match.finished? ? 'text-slate-300' : 'text-[#0a1d13]' %>">
          <%= match.finished? ? "FT" : l(match.kickoff_at, format: "%H:%M") %>
        </div>
      <% end %>
    </div>
  </div>

  <%# 2. MOBILE TOP TRACK: Time, Live Score Badge, and Prediction Tracker Pinned to Right %>
  <div class="flex items-center justify-between md:hidden mb-3.5">
    <div class="flex items-center gap-3">
      <%# Time tracking indicator %>
      <div class="text-[11px] font-mono font-black shrink-0">
        <% if match.live? %>
          <span class="text-sky-500 tracking-wider animate-pulse"><%= t(".live") %></span>
        <% else %>
          <span class="<%= match.finished? ? 'text-slate-300' : 'text-[#0a1d13]' %>">
            <%= match.finished? ? "FT" : l(match.kickoff_at, format: "%H:%M") %>
          </span>
        <% end %>
      </div>

      <%# Match score container %>
      <div
        class="
          flex items-center gap-2 px-2.5 py-1 bg-[#f9faf9] border <%= match.live? ? 'border-sky-200' : 'border-slate-100' %>
          rounded-lg font-mono text-[13px] font-black text-[#0a1d13]
        "
      >
        <span><%= match.started? ? match.home_score : "-" %></span>
        <span class="<%= match.live? ? 'text-sky-400' : 'text-slate-200' %>">:</span>
        <span><%= match.started? ? match.away_score : "-" %></span>
      </div>
    </div>

    <%# High-density User Prediction Statement paired with Points Badge %>
    <div class="flex items-center gap-2 shrink-0">
      <div class="flex flex-col items-end gap-0.5 pr-1">
        <span class="text-[7px] font-black text-slate-400 uppercase tracking-widest"><%= t(".your_guess", default: "Spá") %></span>
        <span class="text-[11px] font-mono font-black text-slate-600">
          <%= my_pred ? "#{my_pred.home_guess} - #{my_pred.away_guess}" : "—" %>
        </span>
      </div>

      <div
        class="
          h-8 min-w-10 px-2 rounded-lg flex items-center justify-center font-mono font-black text-[12px]
          border <%= my_style[0] %> <%= my_style[1] %>
          <%= my_style[2] %>
        "
      >
        +<%= my_pts %>
      </div>
    </div>
  </div>

  <%# 3. CENTER TRACK: Desktop and Mobile Responsive Team Names Matrix (Col-span 7) %>
  <div
    class="
      flex-1 md:col-span-7 flex items-center justify-between md:justify-center min-w-0 md:px-4 mb-1
      md:mb-0
    "
  >
    <%# Home Side %>
    <div class="flex-1 flex items-center justify-start md:justify-end gap-3 min-w-0">
      <span class="md:hidden text-[13px] font-bold text-[#0a1d13] truncate"><%= localized_tla(match.home_team) %></span>
      <span class="hidden md:block text-sm font-bold text-[#0a1d13] truncate"><%= localized_short_name(match.home_team) %></span>
      <div class="w-6 h-6 md:w-7 md:h-7 shrink-0">
        <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" %>
      </div>
    </div>

    <%# Desktop Center Score Pill %>
    <div
      class="
        hidden md:flex mx-6 items-center gap-3 px-4 py-1.5 bg-[#f9faf9] border border-slate-100 rounded-xl
        font-mono text-xl font-black text-[#0a1d13] shrink-0
      "
    >
      <span class="w-4 text-center"><%= match.started? ? match.home_score : "-" %></span>
      <span class="text-slate-200">:</span>
      <span class="w-4 text-center"><%= match.started? ? match.away_score : "-" %></span>
    </div>

    <%# Away Side %>
    <div class="flex-1 flex items-center justify-end md:justify-start gap-3 min-w-0">
      <div class="w-6 h-6 md:w-7 md:h-7 shrink-0">
        <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" %>
      </div>
      <span class="md:hidden text-[13px] font-bold text-[#0a1d13] truncate text-right"><%= localized_tla(match.away_team) %></span>
      <span class="hidden md:block text-sm font-bold text-[#0a1d13] truncate"><%= localized_short_name(match.away_team) %></span>
    </div>
  </div>

  <%# 4. RIGHT TRACK: Desktop Comparison Panel Box (Col-span 4) %>
  <div class="hidden md:flex md:col-span-4 shrink-0 items-center justify-end">
    <% if compare_user %>
      <div
        class="
          flex items-stretch border border-slate-100 rounded-2xl overflow-hidden bg-slate-50/50 w-full
          max-w-[300px]
        "
      >
        <%# Me Column %>
        <div
          class="
            w-[140px] flex items-center justify-between gap-4 px-5 py-2 bg-white relative
            shadow-[4px_0_12px_rgba(0,0,0,0.02)] z-10
          "
        >
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#2d5a43]"></div>
          <span class="text-xs font-mono font-bold text-slate-500"><%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %></span>
          <div
            class="
              min-w-11 h-9 rounded-lg flex items-center justify-center font-mono font-black text-sm border
              <%= my_style[0] %> <%= my_style[1] %>
              <%= my_style[2] %>
            "
          >
            +<%= my_pts %>
          </div>
        </div>
        <%# Competitor Column %>
        <div class="w-[140px] flex items-center justify-between gap-4 px-5 py-2">
          <div
            class="
              min-w-11 h-9 rounded-lg flex items-center justify-center font-mono font-black text-sm border
              <%= comp_style[0] %> <%= comp_style[1] %>
              <%= comp_style[2] %>
            "
          >
            +<%= match.started? ? comp_pts : "?" %>
          </div>
          <span class="text-xs font-mono font-bold text-slate-300"><%= (match.started? && comp_pred) ? "#{comp_pred.home_guess}-#{comp_pred.away_guess}" : "—" %></span>
        </div>
      </div>
    <% else %>
      <div class="flex items-center gap-5">
        <span class="text-xs font-mono font-bold text-slate-500">
          <%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>
        </span>
        <div
          class="
            h-11 w-16 rounded-xl flex items-center justify-center font-mono font-black text-lg border
            transition-all <%= my_style[0] %> <%= my_style[1] %>
            <%= my_style[2] %>
          "
        >
          +<%= my_pts %>
        </div>
      </div>
    <% end %>
  </div>

</div>
