<%# locals: (league_competition:, current_matchday:, active_tab: "standings") %>

<%= turbo_frame_tag :sidebar_panel do %>
  <%# Fluid full-height flex container that dynamically mirrors your center layout columns %>
  <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm flex flex-col h-full overflow-hidden">

    <%# 1. CONTROLS HEADER: Native Link Toggles %>
    <header class="px-6 py-4 bg-[#f9faf9] border-b border-slate-100 shrink-0 flex items-center justify-center">
      <div class="grid grid-cols-2 p-1 bg-slate-100/80 rounded-xl w-full">

        <%# Tab Link: Standings %>
        <%= link_to league_competition_by_year_path(league_slug: league_competition.league.slug, 
                                                competition_code: league_competition.competition.code, 
                                                year: league_competition.season.year, 
                                                tab: "standings"),
                data: { turbo_frame: :sidebar_panel, turbo_action: :advance },
                class: "py-1.5 rounded-lg text-[10px] font-mono font-black uppercase tracking-wider transition-all text-center #{active_tab == 'standings' ? 'bg-white shadow-sm text-[#0a1d13]' : 'text-slate-400 hover:text-[#0a1d13]'}" do %>
          <%= t(".standings_tab", default: "Staða") %>
        <% end %>

        <%# Tab Link: Banter %>
        <%= link_to league_competition_by_year_path(league_slug: league_competition.league.slug, 
                                                competition_code: league_competition.competition.code, 
                                                year: league_competition.season.year, 
                                                tab: "banter"),
                data: { turbo_frame: :sidebar_panel, turbo_action: :advance },
                class: "py-1.5 rounded-lg text-[10px] font-mono font-black uppercase tracking-wider transition-all text-center #{active_tab == 'banter' ? 'bg-white shadow-sm text-[#0a1d13]' : 'text-slate-400 hover:text-[#0a1d13]'}" do %>

          <%# 1. FLOATING CONTAINER FRAME FOR TEXT ALIGNMENT %>
          <span class="relative inline-flex items-center gap-1">
            <%= t(".banter_tab", default: "Heiti potturinn") %>

            <%= turbo_stream_from "unread_messages_#{league_competition.signed_id}" %>
            <%= render partial: "unread_dot",
            locals: {
              unread_messages: @unread_messages,
              league_competition: league_competition,
              user: Current.user,
            } %>
          </span>

        <% end %>

      </div>
    </header>
    <%# 2. THE CONDITIONAL CONDENSED WORKSPACE %>
    <div class="flex-1 min-h-0 relative bg-white flex flex-col">

      <% if active_tab == "banter" %>
        <%# PANE B: THE BANTER WORKSPACE %>
        <div class="flex flex-col flex-1 min-h-0" id="banter_feed">
          <%= turbo_stream_from [league_competition, :comments] %>
          <%= tag.div id: dom_id(league_competition, :comments_panel), class: "flex flex-col flex-1 min-h-0 overflow-hidden" do %>
            <%= render "comments/panel", league_competition: league_competition %>
          <% end %>
        </div>

      <% else %>
        <%# PANE A: THE STANDINGS TABLE %>
        <div class="flex flex-col flex-1 min-h-0">

          <%# FIXED: Refined typographic alignment & context metadata strip %>
          <div
            class="
              px-6 py-2.5 bg-slate-50/50 border-b border-slate-100 flex justify-between items-center text-[10px] font-bold
              text-slate-400 tracking-tight shrink-0
            "
          >
            <span>Keppendur (<%= league_competition.standings.size %>)</span>
            <div class="flex items-center gap-6 pr-2 font-mono text-[9px] uppercase tracking-wider">
              <%# "Beint" handles real-time live point shifts elegantly %>
              <span class="text-[#2d5a43] font-black"><%= t(".live_points_short", default: "") %></span>
              <span class="w-10 text-right text-slate-500 font-black"><%= t(".total_points_short", default: "Samt") %></span>
            </div>
          </div>

          <%# Standings scroll track matrix %>
          <div
            class="
              flex-1 overflow-y-auto divide-y divide-slate-100/60 scrollbar-thin scrollbar-thumb-slate-200 scrollbar-track-transparent
            "
            style="scroll-behavior: smooth;"
          >
            <% league_competition.standings.each do |rank_item| %>
              <% is_me = rank_item.user == Current.user %>
              <% matchday_points = rank_item.respond_to?(:current_matchday_points) ? rank_item.current_matchday_points : 0 %>

              <div
                class="
                  flex items-center justify-between transition-colors select-none group <%= is_me ? 'bg-[#f9faf9]/90 border-y border-[#2d5a43]/20 sticky top-0 bottom-0 z-10' : 'bg-white hover:bg-slate-50/50' %>
                "
              >
                <div class="flex items-center gap-3 min-w-0 flex-1 py-3 pl-6">
                  <span
                    class="
                      w-6 h-6 flex items-center justify-center rounded text-[11px] font-mono font-black shrink-0
                      <%= is_me ? 'bg-[#2d5a43] text-white' : 'bg-slate-50 text-slate-400 border border-slate-100 group-hover:bg-slate-100' %>
                    "
                  >
                    <%= rank_item.rank %>
                  </span>
                  <span class="text-[12px] font-bold text-[#0a1d13] truncate min-w-0 pr-2 <%= 'text-[#2d5a43] font-black' if is_me %>">
                    <%= rank_item.user.name %>
                  </span>
                </div>

                <div class="flex items-center gap-5 shrink-0 pr-8 pl-2">
                  <span
                    class="
                      text-[11px] font-mono font-bold tracking-tight text-center tabular-nums min-w-[28px] px-1 py-0.5 rounded
                      <%= matchday_with_points = matchday_points > 0 %> <%= matchday_with_points ? 'bg-emerald-50 text-emerald-700 font-black' : 'text-slate-300' %>
                    "
                  >
                    <%= matchday_with_points ? "+#{matchday_points}" : "•" %>
                  </span>
                  <span class="w-10 text-right text-[13px] font-mono font-black text-[#0a1d13] tabular-nums">
                    <%= rank_item.total_points %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>

    <%# Pure gradient edge masking layer %>
    <div
      class="
        absolute bottom-0 left-0 right-0 h-8 bg-gradient-to-t from-white to-transparent pointer-events-none z-20
        rounded-b-[2.5rem]
      "
    ></div>
  </div>
<% end %>
