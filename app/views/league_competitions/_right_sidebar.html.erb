<aside class="w-full lg:w-[400px] lg:sticky lg:top-6 order-1 lg:order-2">
  <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm overflow-hidden flex flex-col max-h-[calc(100vh-80px)]">

    <%# 1. STANDINGS HEADER (Shrink-0) %>
    <header class="px-8 py-4 border-b border-slate-50 bg-slate-50/30 flex justify-between items-center shrink-0">
      <h3 class="text-[9px] font-black text-[#0a1d13] uppercase tracking-[0.3em]">Standings</h3>
      <span class="text-[9px] font-mono text-slate-300"><%= @leaderboard.count %> Members</span>
    </header>

    <%# 2. SCROLLABLE LEDGER (The flexible middle) %>
    <%# We use a smaller flex-basis to ensure it gives way to the banter %>
    <div class="flex-1 overflow-y-auto no-scrollbar divide-y divide-slate-50">
      <% @leaderboard.each do |rank_item| %>
        <% is_me = rank_item.user == Current.user %>
        <div class="flex items-center justify-between px-8 py-3 transition-colors <%= is_me ? 'bg-slate-50/80 sticky top-0 z-10' : 'bg-white hover:bg-slate-50/50' %>">
          <div class="flex items-center gap-4">
            <span class="w-5 text-[11px] font-mono font-black <%= is_me ? 'text-[#2d5a43]' : 'text-slate-200' %>"><%= rank_item.rank %></span>
            <span class="text-[11px] font-black text-[#0a1d13] uppercase tracking-tight truncate w-32"><%= rank_item.user.name %></span>
          </div>
          <span class="text-md font-mono font-black text-[#0a1d13] tabular-nums"><%= rank_item.total_points %></span>
        </div>
      <% end %>
    </div>

    <%# 3. BANTER SECTION (Integrated) %>
    <div class="shrink-0 bg-white border-t border-slate-100 min-h-0 flex flex-col">
        <div class="overflow-y-auto no-scrollbar bg-white" id="banter_feed">
            <%= render 'comments_section' %>
        </div>
    </div>

  </div>
</aside>
