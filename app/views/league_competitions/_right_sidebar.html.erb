<%# locals: (league_competition:, current_matchday:) %>

<aside class="w-full lg:w-[400px] lg:sticky lg:top-6 order-1 lg:order-2">
  <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm overflow-hidden flex flex-col h-[calc(100vh-80px)] max-h-[820px]">

    <%# 1. BANTER SECTION (Structured Flex Engine) %>
    <%# h-1/2 matches your split, but flex flex-col handles internal message/input sorting %>
    <div class="h-1/2 flex flex-col min-h-0 bg-white border-b border-slate-100 relative">
      <div class="flex flex-col h-full min-h-0" id="banter_feed">
        <%= turbo_stream_from [league_competition, :comments] %>

        <%= tag.div id: dom_id(league_competition, :comments_panel), class: "flex flex-col h-full min-h-0" do %>
          <%= render 'comments/panel', league_competition: league_competition %>
        <% end %>
      </div>
    </div>

    <%# 2. STANDINGS HEADER (Middle Anchor) %>
    <header class="px-8 py-3.5 border-b border-slate-100 bg-[#f9faf9] flex justify-between items-center shrink-0">
      <h3 class="text-[9px] font-black text-[#0a1d13] uppercase tracking-[0.3em]">
        <%= t('.standings_title', default: "STAÐA") %>
      </h3>
      <span class="text-[9px] font-mono font-bold text-slate-400 bg-slate-100/70 px-2 py-0.5 rounded">
        <%= league_competition.standings.size %> <%= t('dashboard.show.total_members', default: "keppendur") %>
      </span>
    </header>

    <%# 3. SCROLLABLE LEDGER WITH VISUAL FADE %>
    <div class="flex-1 h-1/2 relative min-h-0 flex flex-col">
      
      <%# Scrollable Matrix Box %>
      <div class="overflow-y-auto no-scrollbar divide-y divide-slate-50 flex-1 pb-12">
        <% league_competition.standings.each do |rank_item| %>
          <% is_me = rank_item.user == Current.user %>
          
          <div class="flex items-center justify-between px-8 py-3 transition-colors select-none
                      <%= is_me ? 'bg-[#f9faf9] border-y border-[#2d5a43]/10 sticky top-0 z-10' : 'bg-white hover:bg-slate-50/40' %>">
            
            <div class="flex items-center gap-4 min-w-0 flex-1">
              <span class="w-5 text-[11px] font-mono font-black text-center shrink-0 <%= is_me ? 'text-[#2d5a43]' : 'text-slate-200' %>">
                <%= rank_item.rank %>
              </span>
              
              <span class="text-[12px] font-bold text-[#0a1d13] truncate min-w-0 pr-4 <%= 'text-[#2d5a43] font-black' if is_me %>">
                <%= rank_item.user.name %>
              </span>
            </div>
            
            <span class="text-[13px] font-mono font-black text-[#0a1d13] tabular-nums shrink-0 pl-2">
              <%= rank_item.total_points %>
            </span>
          </div>
        <% end %>
      </div>

      <%# Gradient fade mask blocks hard cuts and signals overflow data below %>
      <div class="absolute bottom-0 left-0 right-0 h-14 bg-gradient-to-t from-white via-white/80 to-transparent pointer-events-none z-20"></div>
      
    </div>

  </div>
</aside>
