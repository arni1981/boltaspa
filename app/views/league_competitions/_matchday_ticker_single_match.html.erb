<%# app/views/leagues/_matchday_ticker_single_match.html.erb %>
<% 
  my_pred = predictions_map[match.id]
  comp_pred = compare_predictions_map&.[](match.id) if compare_user
  
  my_pts = my_pred&.points_won.to_i
  comp_pts = comp_pred&.points_won.to_i
  
  # Binary Winner Logic
  i_win = compare_user && (my_pts > comp_pts)
  comp_wins = compare_user && (comp_pts > my_pts)
%>

<div id="<%= dom_id(match) %>" class="flex items-center px-6 py-4 border-b border-gray-100 bg-white transition-colors">

  <%# 1. TIME %>
  <div class="w-12 shrink-0 font-mono font-black text-[12px] text-[#0a1d13]">
    <%= match.live? ? "LIVE" : match.kickoff_at.strftime("%H:%M") %>
  </div>

  <%# 2. TEAMS & SCORE (Crests Restored) %>
  <div class="flex-1 flex items-center justify-center gap-4">
    <%# Home %>
    <div class="flex-1 flex items-center justify-end gap-3 min-w-0">
      <span class="text-[13px] font-black text-[#0a1d13] uppercase tracking-tight truncate"><%= match.home_team.short_name %></span>
      <div class="w-6 h-6 shrink-0 grayscale-[0.2]">
        <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" if match.home_team.crest_url.present? %>
      </div>
    </div>

    <%# Score %>
    <div class="w-20 flex items-center justify-center gap-2">
      <span class="text-xl font-mono font-black tabular-nums <%= match.live? ? 'text-[#2d5a43]' : 'text-[#0a1d13]' %>">
        <%= match.home_score || 0 %>
      </span>
      <span class="text-slate-100 font-bold">:</span>
      <span class="text-xl font-mono font-black tabular-nums <%= match.live? ? 'text-[#2d5a43]' : 'text-[#0a1d13]' %>">
        <%= match.away_score || 0 %>
      </span>
    </div>

    <%# Away %>
    <div class="flex-1 flex items-center justify-start gap-3 min-w-0">
      <div class="w-6 h-6 shrink-0 grayscale-[0.2]">
        <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" if match.away_team.crest_url.present? %>
      </div>
      <span class="text-[13px] font-black text-[#0a1d13] uppercase tracking-tight truncate"><%= match.away_team.short_name %></span>
    </div>
  </div>

  <%# 3. THE "POINTS FIRST" DUEL %>
  <div class="w-80 shrink-0 ml-6 flex items-center justify-end gap-1 font-mono">
    <% if compare_user %>

      <%# ME (Forest Green if winning) %>
      <div class="flex items-center gap-2 px-3 py-2 rounded transition-all <%= i_win ? 'bg-[#2d5a43] text-white' : 'text-gray-500' %>">
        <span class="text-[14px] font-black">+<%= my_pts %></span>
        <span class="text-[10px] font-bold opacity-60 tracking-tighter">(<%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>)</span>
      </div>

      <div class="w-px h-4 bg-gray-100 mx-1"></div>

      <%# THEM (Midnight Green if winning) %>
      <div class="flex items-center gap-2 px-3 py-2 rounded transition-all <%= comp_wins ? 'bg-[#0a1d13] text-white' : 'text-gray-500' %>">
        <span class="text-[14px] font-black">
          <%= match.started? ? "+#{comp_pts}" : "?" %>
        </span>
        <span class="text-[10px] font-bold opacity-60 tracking-tighter">
          (<%= (match.started? && comp_pred) ? "#{comp_pred.home_guess}-#{comp_pred.away_guess}" : "—" %>)
        </span>
      </div>

    <% else %>
      <%# SOLO VIEW %>
      <div class="px-4 py-2 rounded flex items-center gap-2 transition-all <%= my_pts > 0 ? 'bg-[#2d5a43] text-white' : 'text-gray-500 border border-gray-100' %>">
        <span class="text-[15px] font-black">+<%= my_pts %></span>
        <span class="text-[11px] font-bold opacity-60 tracking-tighter">(<%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>)</span>
      </div>
    <% end %>
  </div>
</div>
