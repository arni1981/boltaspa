<%# locals: (match:, predictions_map:, compare_predictions_map: nil, compare_user: nil) %>

<% 
  my_pred = predictions_map[match.id]
  comp_pred = compare_predictions_map&.[](match.id) if compare_user
  
  my_pts = my_pred&.points_won.to_i
  comp_pts = comp_pred&.points_won.to_i
    
  score_color = match.started? ? 'text-[#0a1d13]' : 'text-slate-200'
  row_bg = match.live? ? 'bg-emerald-50/40' : 'bg-white hover:bg-gray-50/80'
%>

<%= turbo_stream_from match %>
<div id="<%= dom_id(match) %>" class="flex items-center px-6 py-4 border-b border-gray-100 transition-colors group <%= row_bg %>">

  <%# 1. TIME & DATE (Vertical Stack) %>
  <div class="w-16 shrink-0 flex flex-col justify-center">
    <% if match.live? %>
      <span class="text-[10px] font-mono font-black text-[#2d5a43] animate-pulse">LIVE</span>
      <span class="text-[10px] font-mono font-black text-[#2d5a43]"><%= match.minute %>'</span>
    <% else %>
      <%# The Date: Small, subtle anchor %>
      <span class="text-[8px] font-black text-slate-400 uppercase tracking-tighter leading-none mb-1">
        <%= l(match.kickoff_at, format: "%d. %b") %>
      </span>
      <%# The Time: The primary focus %>
      <span class="text-[11px] font-mono font-bold text-[#0a1d13] leading-none">
        <%= match.kickoff_at.strftime("%H:%M") %>
      </span>
    <% end %>
  </div>

  <%# 2. TEAMS & LIVE SCORE %>
  <div class="flex-1 flex items-center justify-center">
    <div class="flex-1 flex items-center justify-end gap-3 min-w-0">
      <span class="text-[12px] font-black text-[#0a1d13] uppercase tracking-tight truncate">
        <%= match.home_team.short_name %>
      </span>
      <div class="w-6 h-6 shrink-0">
        <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" if match.home_team.crest_url.present? %>
      </div>
    </div>

    <div class="w-20 flex items-center justify-center gap-2 mx-4">
      <span class="text-lg font-mono font-black tabular-nums <%= score_color %>">
        <%= match.home_score || 0 %>
      </span>
      <span class="text-slate-200 font-bold">:</span>
      <span class="text-lg font-mono font-black tabular-nums <%= score_color %>">
        <%= match.away_score || 0 %>
      </span>
    </div>

    <div class="flex-1 flex items-center justify-start gap-3 min-w-0">
      <div class="w-6 h-6 shrink-0">
        <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" if match.away_team.crest_url.present? %>
      </div>
      <span class="text-[12px] font-black text-[#0a1d13] uppercase tracking-tight truncate">
        <%= match.away_team.short_name %>
      </span>
    </div>
  </div>

  <%# 3. PREDICTIONS (Gated Comparison) %>
  <div class="w-72 shrink-0 ml-6 flex items-center justify-end">
    <% if compare_user %>
      <div class="flex items-center gap-2">

        <%# Me: Always visible to me %>
        <div class="flex items-center gap-2 px-3 py-1.5 bg-gray-50 rounded-xl border border-gray-100">
          <span class="text-[11px] font-mono font-black text-[#0a1d13]">
            <%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>
          </span>
          <div class="w-8 h-5 flex items-center justify-center rounded-lg <%= my_pts > 0 ? 'bg-[#2d5a43] text-white' : 'bg-slate-200 text-white' %>">
            <span class="text-[9px] font-black font-mono">+<%= my_pts %></span>
          </div>
        </div>

        <span class="text-slate-200 font-bold px-1">vs</span>

        <%# Competitor: GATED logic %>
        <div class="flex items-center gap-2 px-3 py-1.5 bg-[#0a1d13] rounded-xl border border-[#0a1d13]">
          <span class="text-[11px] font-mono font-black text-white/90">
            <% if match.started? %>
              <%= comp_pred ? "#{comp_pred.home_guess}-#{comp_pred.away_guess}" : "—" %>
            <% else %>
              <%# Hidden state: locked icon or question mark %>
              <svg class="w-3 h-3 text-white/20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 15v2h-2v-2h2zm2-4v2h-4v-2h4zm2-8v2h-2V3h2zm0 18v2h-2v-2h2zM4 3h2v2H4V3zm0 18h2v2H4v-2zM18 3h2v2h-2V3zm0 18h2v2h-2v-2zM4 9h2v2H4V9zm0 4h2v2H4v-2zm14-4h2v2h-2V9zm0 4h2v2h-2v-2z" opacity=".2"/>
                <rect x="7" y="7" width="10" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="2" stroke-opacity="0.3"/>
              </svg>
            <% end %>
          </span>

          <div class="w-8 h-5 flex items-center justify-center rounded-lg <%= (match.started? && comp_pts > 0) ? 'bg-[#2d5a43] text-white' : 'bg-white/10 text-white/30' %>">
            <span class="text-[9px] font-black font-mono">
              <%= match.started? ? "+#{comp_pts}" : "?" %>
            </span>
          </div>
        </div>

      </div>
    <% else %>
      <%# Solo View %>
      <div class="flex items-center gap-3">
        <span class="text-[13px] font-mono font-black text-[#0a1d13]">
          <%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>
        </span>
        <div class="px-3 py-1 rounded-lg border-2 <%= my_pts > 0 ? 'border-[#2d5a43]/20 bg-emerald-50 text-[#2d5a43]' : 'border-dashed border-slate-100 text-slate-200' %>">
          <span class="text-[11px] font-mono font-black">+<%= my_pts %></span>
        </div>
      </div>
    <% end %>
  </div>
</div>
