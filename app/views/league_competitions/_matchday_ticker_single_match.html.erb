<%# locals: (match:, predictions_map:, compare_predictions_map: nil, compare_user: nil) %>

<% 
  my_pred = predictions_map[match.id]
  comp_pred = compare_predictions_map&.[](match.id) if compare_user
  
  my_pts = my_pred&.points_won.to_i
  comp_pts = comp_pred&.points_won.to_i

  # Sync Logic: Did I get the Bullseye?
  is_synced = my_pts == 25
  
  # Winner Logic for Duel highlights
  i_win = compare_user && (my_pts > comp_pts)
  comp_wins = compare_user && (comp_pts > my_pts)
%>

<%= turbo_stream_from match %>

<div id="<%= dom_id(match) %>" 
     class="group relative flex items-center px-8 py-6 border-b border-slate-100 bg-white hover:bg-[#f9faf9] transition-all duration-500">

  <%# 1. LIVE HEARTBEAT / KICKOFF %>
  <div class="w-20 shrink-0 flex flex-col gap-1">
    <% if match.live? %>
      <div class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-sky-500"></span>
        </span>
        <span class="text-[10px] font-black text-sky-600 uppercase tracking-[0.2em]">Live</span>
      </div>
      <span class="text-[11px] font-mono font-black text-[#0a1d13]">
        <%= match.minute %>'<span class="animate-pulse opacity-50">_</span>
      </span>
    <% elsif match.finished? %>
      <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Finished</span>
      <span class="text-[11px] font-mono font-bold text-slate-400">FT</span>
    <% else %>
      <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest">Kickoff</span>
      <span class="text-[11px] font-mono font-bold text-[#0a1d13]"><%= l match.kickoff_at, format: "%H:%M" %></span>
    <% end %>
  </div>

  <%# 2. MATCH DISPLAY: The Engine Room %>
  <div class="flex-1 flex items-center justify-center gap-4 lg:gap-10">

    <%# Home Team %>
    <div class="flex-1 flex items-center justify-end gap-4">
      <span class="text-[13px] font-black text-[#0a1d13] uppercase tracking-tighter truncate">
        <%= match.home_team.short_name %>
      </span>
      <div class="w-8 h-8 shrink-0 grayscale group-hover:grayscale-0 transition-all duration-700">
        <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" if match.home_team.crest_url.present? %>
      </div>
    </div>

    <%# SCOREBOARD %>
    <div class="relative">
      <div class="flex items-center bg-[#0a1d13] text-white px-5 py-2 rounded-xl font-mono text-xl font-black tabular-nums tracking-tighter shadow-xl shadow-midnight/10 border-2 transition-all duration-500 <%= is_synced ? 'border-[#2d5a43]' : 'border-transparent' %>">
        <span class="<%= 'text-[#2d5a43]' if is_synced %>"><%= match.home_score || 0 %></span>
        <span class="mx-2 opacity-20 text-sm">:</span>
        <span class="<%= 'text-[#2d5a43]' if is_synced %>"><%= match.away_score || 0 %></span>
      </div>
      <% if is_synced && match.live? %>
        <div class="absolute -top-2 -right-2 bg-[#2d5a43] text-[7px] px-1.5 py-0.5 rounded-md font-black uppercase text-white animate-bounce">Sync</div>
      <% end %>
    </div>

    <%# Away Team %>
    <div class="flex-1 flex items-center justify-start gap-4">
      <div class="w-8 h-8 shrink-0 grayscale group-hover:grayscale-0 transition-all duration-700">
        <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" if match.away_team.crest_url.present? %>
      </div>
      <span class="text-[13px] font-black text-[#0a1d13] uppercase tracking-tighter truncate">
        <%= match.away_team.short_name %>
      </span>
    </div>
  </div>

  <%# 3. POINTS DUEL / SOLO DISPLAY %>
  <div class="w-64 shrink-0 flex items-center justify-end gap-3">
    <% if compare_user %>
      <%# USER 1 (YOU) %>
      <div class="flex items-center gap-3 pr-3 border-r border-slate-100">
        <div class="text-right">
          <span class="block text-[8px] font-bold text-slate-300 uppercase tracking-widest">You</span>
          <span class="block text-[11px] font-mono font-bold text-slate-400">
            <%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>
          </span>
        </div>
        <div class="h-10 w-10 rounded-xl flex items-center justify-center font-mono font-black text-sm transition-all <%= i_win ? 'bg-[#2d5a43] text-white shadow-lg' : 'bg-slate-50 text-slate-400' %>">
          +<%= my_pts %>
        </div>
      </div>

      <%# USER 2 (OPPONENT) %>
      <div class="flex items-center gap-3 pl-1">
        <div class="h-10 w-10 rounded-xl flex items-center justify-center font-mono font-black text-sm transition-all <%= comp_wins ? 'bg-[#0a1d13] text-white shadow-lg' : 'bg-slate-50 text-slate-400' %>">
          <%= match.started? ? "+#{comp_pts}" : "?" %>
        </div>
        <div class="text-left">
          <span class="block text-[8px] font-bold text-slate-300 uppercase tracking-widest truncate w-12">
            <%= compare_user.name.split.first %>
          </span>
          <span class="block text-[11px] font-mono font-bold text-slate-400">
            <%= (match.started? && comp_pred) ? "#{comp_pred.home_guess}-#{comp_pred.away_guess}" : "—" %>
          </span>
        </div>
      </div>

    <% else %>
      <%# SOLO VIEW %>
      <div class="flex items-center gap-4">
        <div class="text-right">
          <span class="block text-[9px] font-black text-slate-300 uppercase tracking-[0.2em] mb-0.5">Prediction</span>
          <span class="block text-[13px] font-mono font-black <%= is_synced ? 'text-[#2d5a43]' : 'text-[#0a1d13] opacity-40' %>">
            <%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>
          </span>
        </div>
        <div class="h-14 w-14 rounded-2xl flex flex-col items-center justify-center shadow-md transition-all duration-500 <%= is_synced ? 'bg-[#2d5a43] text-white shadow-[#2d5a43]/20' : 'bg-[#0a1d13] text-white' %>">
          <span class="text-[8px] font-black uppercase opacity-60">Pts</span>
          <span class="font-mono font-black text-xl">+<%= my_pts %></span>
        </div>
      </div>
    <% end %>
  </div>

</div>
