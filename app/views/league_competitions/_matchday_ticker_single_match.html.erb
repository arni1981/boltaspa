<%# locals: (match:, predictions_map:, compare_predictions_map: nil, compare_user: nil) %>

<% 
  my_pred = predictions_map[match.id]
  comp_pred = compare_predictions_map&.[](match.id) if compare_user
  
  my_pts = my_pred&.points_won.to_i
  comp_pts = comp_pred&.points_won.to_i

  # THE PERFORMANCE ENGINE
  # Returns: [Background Class, Text Class, Border Class]
  def performance_tier(pts)
    return ["bg-transparent", "text-slate-200", "border-slate-100"] if pts == 0
    return ["bg-[#2d5a43]", "text-white", "border-[#2d5a43] shadow-sm"] if pts == 25
    
    # 12+ is the "Pro" zone (Outcome correct + some proximity)
    if pts >= 12
      ["bg-[#0a1d13]", "text-white", "border-[#0a1d13]"]
    else
      ["bg-white", "text-[#0a1d13]", "border-slate-200"]
    end
  end

  my_style = performance_tier(my_pts)
  comp_style = performance_tier(comp_pts)
%>

<%= turbo_stream_from match %>

<div id="<%= dom_id(match) %>" 
     class="flex items-center px-8 py-5 border-b border-slate-100 bg-white hover:bg-[#f9faf9] transition-all duration-300">

  <%# 1. FIXED STATUS UNIT (Left Column) %>
  <div class="w-20 shrink-0">
    <% if match.live? %>
      <div class="inline-flex items-center gap-1.5 px-2 py-0.5 bg-sky-500 rounded text-white mb-1 shadow-sm">
        <span class="flex h-1.5 w-1.5 rounded-full bg-white animate-pulse"></span>
        <span class="text-[9px] font-black uppercase tracking-widest">Live</span>
      </div>
      <div class="text-sm font-mono font-black text-[#0a1d13]"><span class="text-sky-500 animate-pulse">'</span></div>
    <% else %>
      <div class="text-sm font-mono font-bold <%= match.finished? ? 'text-slate-300' : 'text-[#0a1d13]' %>">
        <%= match.finished? ? "FT" : l(match.kickoff_at, format: "%H:%M") %>
      </div>
    <% end %>
  </div>

  <%# 2. CENTER ENGINE: Use fixed widths for team name containers to lock the score in place %>
  <div class="flex-1 flex items-center justify-center">
    <%# Home Team Container - FIXED WIDTH %>
    <div class="w-40 flex items-center justify-end gap-3 text-right">
      <span class="text-sm font-black text-[#0a1d13] uppercase tracking-tighter truncate"><%= match.home_team.short_name %></span>
      <div class="w-7 h-7 shrink-0"><%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" %></div>
    </div>

    <%# The Score Pill - CENTERED ANCHOR %>
    <div class="mx-6 flex items-center gap-3 px-4 py-1.5 bg-[#f9faf9] border border-slate-100 rounded-xl font-mono text-xl font-black tabular-nums tracking-tighter text-[#0a1d13]">
      <span class="w-4 text-center"><%= match.started? ? match.home_score : "-" %></span>
      <span class="text-slate-200 text-xs">:</span>
      <span class="w-4 text-center"><%= match.started? ? match.away_score : "-" %></span>
    </div>

    <%# Away Team Container - FIXED WIDTH %>
    <div class="w-40 flex items-center justify-start gap-3 text-left">
      <div class="w-7 h-7 shrink-0"><%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" %></div>
      <span class="text-sm font-black text-[#0a1d13] uppercase tracking-tighter truncate"><%= match.away_team.short_name %></span>
    </div>
  </div>

  <%# 3. FIXED DATA UNIT (Right Column) %>
  <div class="w-[320px] shrink-0 flex items-center justify-end">
    <% if compare_user %>
      <div class="flex items-stretch border border-slate-100 rounded-2xl overflow-hidden bg-slate-50/50">
        <%# YOU (Left Anchor) %>
        <div class="w-[140px] flex items-center justify-between gap-4 px-5 py-2 bg-white relative shadow-[4px_0_12px_rgba(0,0,0,0.02)] z-10">
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#2d5a43]"></div>
          <span class="text-xs font-mono font-bold text-slate-500"><%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %></span>
          <div class="min-w-[44px] h-9 rounded-lg flex items-center justify-center font-mono font-black text-sm border <%= my_style[0] %> <%= my_style[1] %> <%= my_style[2] %>">
            +<%= my_pts %>
          </div>
        </div>

        <%# THEM (Right Anchor) %>
        <div class="w-[140px] flex items-center justify-between gap-4 px-5 py-2">
          <div class="min-w-[44px] h-9 rounded-lg flex items-center justify-center font-mono font-black text-sm border <%= comp_style[0] %> <%= comp_style[1] %> <%= comp_style[2] %>">
            +<%= match.started? ? comp_pts : "?" %>
          </div>
          <span class="text-xs font-mono font-bold text-slate-300"><%= (match.started? && comp_pred) ? "#{comp_pred.home_guess}-#{comp_pred.away_guess}" : "—" %></span>
        </div>
      </div>
    <% else %>
      <%# Solo view needs a fixed width container too to keep the points badge aligned %>
      <div class="flex items-center gap-5">
        <span class="text-xs font-mono font-bold text-slate-500">
          <%= my_pred ? "#{my_pred.home_guess}-#{my_pred.away_guess}" : "—" %>
        </span>
        <div class="h-11 w-16 rounded-xl flex items-center justify-center font-mono font-black text-lg border transition-all <%= my_style[0] %> <%= my_style[1] %> <%= my_style[2] %>">
          +<%= my_pts %>
        </div>
      </div>
    <% end %>
  </div>
</div>
