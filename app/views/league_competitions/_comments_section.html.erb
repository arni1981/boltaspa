<%# locals: (league_competition:, current_matchday:) %>

<%= turbo_stream_from league_competition %>

<%= turbo_frame_tag :comments do %>
  <div class="flex flex-col bg-white overflow-hidden">
    <%# 1. HEADER %>
    <header class="px-8 py-4 bg-slate-50/30 border-b border-slate-50 flex justify-between items-center shrink-0">
      <h3 class="text-[9px] font-black text-[#0a1d13] uppercase tracking-[0.3em]">
        <%= t('.title', default: 'PALLBORÐIÐ') %>
      </h3>
      <span class="text-[8px] font-mono text-slate-300 uppercase tracking-widest">
        <%= league_competition.comments&.count %> Feed
      </span>
    </header>

    <%# 2. FEED: Fixed height with no-scrollbar %>
    <div class="px-8 py-5 space-y-5 max-h-[320px] min-h-[200px] overflow-y-auto no-scrollbar" id="banter_list">
      <% league_competition.comments.ordered.each do |comment| %>
        <div class="group">
          <div class="flex items-baseline gap-2 mb-0.5">
            <span class="text-[10px] font-black text-[#0a1d13] uppercase tracking-tight">
              <%= comment.user.name %>
            </span>
            <span class="text-[8px] font-mono font-bold text-slate-200">
              <%= l(comment.created_at, format: :only_time) %>
            </span>
          </div>
          <p class="text-[12px] text-slate-500 leading-snug">
            <%= comment.body %>
          </p>
        </div>
      <% end %>
    </div>

    <%# 3. INPUT: Fixed within bounds %>
    <div class="px-8 py-5 bg-white border-t border-slate-50 shrink-0">
      <%= form_with model: [ league_competition.league, league_competition, Comment.new ],
          class: "flex items-center gap-2 relative",
          data: { turbo_frame: "_self", controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
        <%= f.hidden_field :matchday, value: current_matchday %>

        <div class="relative flex-1">
          <%= f.text_field :body, 
              placeholder: t('.placeholder', default: 'Hvað finnst þér?'), 
              class: "w-full bg-slate-50 border-transparent rounded-[1rem] text-[11px] py-3 pl-4 pr-12 focus:ring-0 focus:border-[#2d5a43] placeholder:text-slate-300 transition-all",
              autocomplete: "off" %>

          <button type="submit" class="absolute right-1.5 top-1.5 bottom-1.5 bg-[#0a1d13] text-white px-3 rounded-[0.75rem] transition-all hover:bg-[#2d5a43] active:scale-95 flex items-center justify-center shrink-0">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
