<%# locals: (league:, league_competition:, comments:, current_matchday:) %>
<%= turbo_stream_from league_competition %>

<%= turbo_frame_tag :comments do %>
  <%# No extra borders or shadows here, it inherits from the sidebar parent %>
  <div class="flex flex-col">
    <%# THE SINGLE HEADER %>
    <header class="px-8 py-3 bg-slate-50/30 border-b border-slate-50 flex justify-between items-center shrink-0">
      <h3 class="text-[9px] font-black text-[#0a1d13] uppercase tracking-[0.3em]">
        <%= t('.title') %>
      </h3>
      <span class="text-[8px] font-mono text-slate-300 uppercase tracking-widest">
        <%= comments&.count %> Feed
      </span>
    </header>

    <%# THE FEED: High density, no-scrollbar %>
    <div class="px-8 py-5 space-y-4 max-h-[280px] overflow-y-auto no-scrollbar bg-white" id="banter_list">
      <% comments.each do |comment| %>
        <div class="group">
          <div class="flex items-baseline gap-2 mb-0.5">
            <span class="text-[10px] font-black text-[#0a1d13] uppercase tracking-tight">
              <%= comment.user.name %>
            </span>
            <span class="text-[8px] font-mono font-bold text-slate-200">
              <%= l(comment.created_at, format: :only_time) %>
            </span>
          </div>
          <p class="text-[12px] text-slate-500 leading-snug">
            <%= comment.body %>
          </p>
        </div>
      <% end %>
    </div>

    <%# THE INPUT: Pinned to the bottom of the sidebar section %>
    <div class="px-8 py-4 bg-white border-t border-slate-50 shrink-0">
      <%= form_with model: [ league, league_competition, Comment.new ],
          class: "flex items-center gap-2",
          data: { turbo_frame: "_self" } do |f| %>
        <%= f.hidden_field :matchday, value: current_matchday %>

        <%= f.text_field :body, 
            placeholder: t('.placeholder'), 
            class: "flex-1 bg-slate-50 border-transparent rounded-xl text-xs py-2 px-4 focus:ring-0 focus:border-[#2d5a43] placeholder:text-slate-300",
            autocomplete: "off" %>

        <button type="submit" class="bg-[#0a1d13] text-white p-2.5 rounded-xl transition-all hover:bg-[#2d5a43] active:scale-95 shrink-0">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      <% end %>
    </div>
  </div>
<% end %>
