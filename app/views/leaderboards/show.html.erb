<%= render 'layouts/shared/page_header', 
    title: @league_competition.competition.name, 
    crest: @league_competition.competition.emblem,
    breadcrumbs: [
      { name: t('common.home'), path: root_path },
      { name: t('.breadcrumb_leagues'), path: leagues_path }, 
      { name: @league_competition.league.name, path: league_path(@league_competition.league) }] %>


<div class="max-w-7xl mx-auto py-12 px-6">
  <section class="bg-white border border-gray-100 rounded-[2.5rem] shadow-sm overflow-hidden">

    <header class="px-10 py-8 bg-[#0a1d13] flex items-center justify-between">
      <h2 class="text-xl font-black text-white uppercase tracking-tight">
        Detailed Standings
      </h2>
    </header>

    <div class="overflow-x-auto">
      <table class="w-full text-left border-separate border-spacing-0">
        <thead>
          <tr class="bg-gray-50">
            <%# RANK: 0px to 80px %>
            <th class="sticky left-0 z-30 bg-gray-50 py-5 pl-10 w-20 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-gray-100">Rank</th>

            <%# COMPETITOR: 80px to 260px %>
            <th class="sticky left-20 z-30 bg-gray-50 px-6 py-5 w-[180px] text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-gray-100">Competitor</th>

            <%# TOTAL: Starts at 260px (80 + 180) %>
            <th class="sticky left-[260px] z-30 bg-emerald-50 px-6 py-5 w-24 text-[10px] font-black text-[#2d5a43] uppercase tracking-widest text-right border-b border-emerald-100 shadow-[2px_0_5px_-2px_rgba(0,0,0,0.1)]">Total</th>

            <%# Matchdays: Normal scroll %>
            <% @matchdays.each do |md| %>
              <th class="px-4 py-5 text-[9px] font-black text-slate-300 uppercase text-center w-20 border-b border-gray-100">MD <%= md %></th>
            <% end %>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-50">
          <% @league_competition.standings.each_with_index do |standing, i| %>
            <tr class="group">
              <%# RANK CELL %>
              <td class="sticky left-0 z-20 bg-white group-hover:bg-[#f9faf9] py-6 pl-10 font-mono text-sm font-black text-slate-300 transition-colors">
                #<%= i + 1 %>
              </td>

              <%# COMPETITOR CELL: Forced width to match header %>
              <td class="sticky left-20 z-20 bg-white group-hover:bg-[#f9faf9] px-6 py-6 transition-colors w-[180px]">
                <span class="text-sm font-black text-[#0a1d13] uppercase truncate block w-[140px]"><%= standing.user.name %></span>
              </td>

              <%# TOTAL CELL: Hard offset at 260px %>
              <td class="sticky left-[260px] z-20 bg-emerald-50 group-hover:bg-emerald-100/50 px-6 py-6 text-right transition-colors shadow-[2px_0_5px_-2px_rgba(0,0,0,0.1)] border-r border-emerald-100/30">
                <span class="text-lg font-mono font-black text-[#2d5a43]">
                  <%= standing.total_points %>
                </span>
              </td>

              <%# MATCHDAY CELLS %>
              <% @matchdays.each do |matchday| %>
                <td class="px-4 py-6 text-center font-mono text-xs text-slate-400 group-hover:text-[#0a1d13] border-l border-gray-50/50">
                  <%= standing.full_form_array[matchday.to_s] || '0' %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
