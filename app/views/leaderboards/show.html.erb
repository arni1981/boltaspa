<%# app/views/leaderboards/show.html.erb %>

<%= render "layouts/shared/page_header",
title: @league_competition.competition.name,
crest: @league_competition.competition.emblem,
breadcrumbs: [
  { name: t("common.home"), path: root_path },
  { name: t(".breadcrumb_leagues"), path: leagues_path },
  { name: @league_competition.league.name, path: league_path(@league_competition.league) },
] %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="bg-white border border-gray-100 rounded-[2.5rem] shadow-sm overflow-hidden">

    <%# 1. CLEAN TRACKING HEADER %>
    <header class="px-6 md:px-10 py-6 bg-[#0a1d13]">
      <span class="text-[8px] font-black text-[#2d5a43] uppercase tracking-[0.4em] mb-1 block">
        Yfirlitið
      </span>
      <h2 class="text-xl font-black text-white uppercase tracking-tight">
        Heildarárangur eftir umferðum
      </h2>
    </header>

    <%# 2. DYNAMIC MATRIX CONTAINER %>
    <% grid_layout_style =
      "grid-template-columns: 32px minmax(120px, 3fr) repeat(#{@stages.size}, minmax(70px, 1fr)) 80px;" %>

    <div class="overflow-x-auto">
      <div class="inline-w-full min-w-[700px] divide-y divide-gray-50">

        <%# COLUMN HEADERS %>
        <div
          class="
            grid items-center px-6 md:px-10 py-4 bg-[#f9faf9] text-[10px] font-mono font-black uppercase
            tracking-wider text-slate-400 gap-4
          "
          style="<%= grid_layout_style %>"
        >
          <span>#</span>
          <span>Keppandi</span>

          <%# Dynamic Stage Columns %>
          <% @stages.each do |stage| %>
            <div
              class="text-center truncate"
              title="<%= t("competitions.stages.#{stage.downcase}", default: stage.humanize) %>"
            >
              <%= t("competitions.stages.#{stage.downcase}", default: stage.humanize) %>
            </div>
          <% end %>

          <div class="text-right text-[#0a1d13]">Samtals</div>
        </div>

        <%# STANDINGS ROW LOOP %>
        <% @league_competition.standings.each do |standing| %>
          <% is_viewer = (standing.user_id == Current.user.id) %>

          <div
            class="
              grid items-center px-6 md:px-10 py-4 transition-colors gap-4 <%= is_viewer ? 'bg-[#2d5a43]/5' : 'bg-white hover:bg-[#f9faf9]' %>
            "
            style="<%= grid_layout_style %>"
          >

            <%# Position Rank %>
            <span class="font-mono font-bold text-sm <%= is_viewer ? 'text-[#2d5a43]' : 'text-slate-400' %>">
              <%= standing.rank %>.
            </span>

            <%# Competitor Name %>
            <span class="text-sm font-black text-[#0a1d13] truncate">
              <%= standing.user.name %>
            </span>

            <%# Dynamic Stage Values %>
            <% @stages.each do |stage| %>
              <% pts = standing.full_stage_array[stage] %>
              <div class="text-center font-mono text-sm">
                <% if pts.positive? %>
                  <span class="font-black text-[#3a86ff]"><%= pts %></span>
                <% else %>
                  <span class="text-slate-300">0</span>
                <% end %>
              </div>
            <% end %>

            <%# Ultimate Grand Total Marathon Column %>
            <div class="text-right">
              <span class="font-mono text-base font-black text-[#0a1d13]">
                <%= standing.total_points %>
              </span>
            </div>

          </div>
        <% end %>

      </div>
    </div>

  </div>
</div>
