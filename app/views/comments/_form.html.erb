<%# locals: (league_competition:, comment: nil) %>

<%= form_with model: [ league_competition, Comment.new ],
    class: "flex items-center gap-2 relative" do |f| %>

  <div class="relative flex-1">
    <%= f.text_field :body, 
        placeholder: t('.placeholder', default: 'Hvað finnst þér?'), 
        class: "w-full bg-slate-50 border-transparent rounded-[1rem] text-[11px] py-3 pl-4 pr-12 focus:ring-0 focus:border-[#2d5a43] placeholder:text-slate-300 transition-all",
        autocomplete: "off" %>

    <button type="submit" class="absolute right-1.5 top-1.5 bottom-1.5 bg-[#0a1d13] text-white px-3 rounded-[0.75rem] transition-all hover:bg-[#2d5a43] active:scale-95 flex items-center justify-center shrink-0">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path d="M5 12h14M12 5l7 7-7 7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
<% end %>
