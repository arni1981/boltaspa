<div class="group">
  <div class="flex items-baseline gap-2 mb-0.5">
    <span class="text-[10px] font-black text-[#0a1d13] uppercase tracking-tight">
      <%= comment.user.name %>
    </span>
    <span class="text-[8px] font-mono font-bold text-slate-200">
      <%= l(comment.created_at, format: :only_time) %>
    </span>
  </div>
  <p class="text-[12px] text-slate-500 leading-snug">
    <%= comment.body %>
  </p>
</div>
