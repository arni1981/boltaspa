<%# locals: (comment:) %>

<div
  class="
    flex flex-col gap-1 border-l-2 border-slate-100 pl-4 hover:border-[#2d5a43]/40 transition-colors select-none py-0.5
    items-start
  "
>

  <%# Header block: Case-natural names paired with clean mono timestamps %>
  <div class="flex items-baseline gap-2">
    <span class="text-[11px] font-black text-[#0a1d13] tracking-tight">
      <%= comment.user.name.split.first %>
    </span>
    <span class="text-[9px] font-mono font-bold text-slate-400">
      <%= l(comment.created_at, format: :short) %>
    </span>
  </div>

  <%# Clean statement layer using refined leading and matching brand slate tones %>
  <div class="text-[12px] text-slate-600 font-medium leading-relaxed tracking-tight max-w-[98%] break-words">
    <%= comment.body %>
  </div>

</div>
