<%# locals: (ranking:, highlight_home_id:, highlight_away_id:) %>
<% is_target = (ranking.team_id == highlight_home_id || ranking.team_id == highlight_away_id) %>

<tr
  class="text-center transition-colors <%= is_target ? 'bg-[#0a1d13]/[0.02] font-bold text-[#0a1d13]' : 'text-slate-500' %>"
>

  <%# Position %>
  <td
    class="py-2.5 pl-4 text-left font-mono <%= is_target ? 'text-[#2d5a43] font-black' : 'text-slate-400' %>"
  >
    <%= ranking.position %>
  </td>

  <%# Team Code %>
  <td
    class="
      text-left font-sans text-[12px] font-bold tracking-wide text-[#0a1d13]
      <%= 'text-[#2d5a43]' if is_target %>
    "
  >
    <%= localized_tla(ranking.team) %>
  </td>

  <%# Clean Data Line %>
  <td class="font-mono <%= 'text-[#0a1d13]' if is_target %>"><%= ranking.played_games %></td>
  <td class="font-mono text-slate-400/70 <%= 'text-[#0a1d13]' if is_target %>"><%= ranking.won %></td>
  <td class="font-mono text-slate-400/70 <%= 'text-[#0a1d13]' if is_target %>"><%= ranking.draw %></td>
  <td class="font-mono text-slate-400/70 <%= 'text-[#0a1d13]' if is_target %>"><%= ranking.lost %></td>

  <%# Goals For : Against %>
  <td class="font-mono text-slate-400 tracking-tight <%= 'text-[#0a1d13]' if is_target %>">
    <%= ranking.goals_for %>:<%= ranking.goals_against %>
  </td>

  <%# Points %>
  <td
    class="py-2.5 pr-4 text-right font-mono text-[13px] <%= is_target ? 'text-[#2d5a43] font-black' : 'text-[#0a1d13] font-black' %>"
  >
    <%= ranking.points %>
  </td>

</tr>
