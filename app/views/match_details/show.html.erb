<%= turbo_frame_tag :match_sidebar do %>
  <%# Hidden on mobile viewports, mounts strictly from lg screens upwards %>
  <div
    class="
      hidden lg:block font-sans text-[13px] text-[#0a1d13] space-y-6 animate-fade-in antialiased
    "
  >

    <div class="border-b border-slate-200/60 pb-3">
      <div class="text-[10px] uppercase font-bold text-slate-400 tracking-widest">Tölfræði Leiks</div>
      <div class="text-[15px] font-semibold tracking-tight mt-0.5 text-[#0a1d13]">
        <%= localized_short_name(@home_team) %>
        <span class="text-slate-300 mx-0.5 font-normal">v</span>
        <%= localized_short_name(@away_team) %>
      </div>
      <% if @match.group.present? %>
        <div
          class="
            text-[10px] font-mono text-[#2d5a43] mt-1.5 bg-emerald-50 border border-emerald-100/30 px-2 py-0.5
            rounded inline-block
          "
        >
          <% group_letter = @match.group.to_s.split("_").last %>
          <%= t("matches.group_format", letter: group_letter) %>
        </div>
      <% end %>
    </div>

    <% if @group_rankings.any? %>
      <div>
        <div
          class="
            bg-white border border-slate-100 rounded-xl overflow-hidden shadow-sm divide-y divide-slate-100
            font-mono text-xs
          "
        >
          <%= render partial: "ranking_row",
          collection: @group_rankings,
          as: :ranking,
          locals: {
            highlight_home_id: @home_team.id,
            highlight_away_id: @away_team.id,
          } %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
