<div
  class="
    bg-[#f9faf9] min-h-screen text-[#0a1d13] flex flex-col items-center px-6
    selection:bg-[#2d5a43] selection:text-white
  "
>

  <nav
    class="
      w-full max-w-5xl py-12 flex items-center justify-between border-b
      border-gray-100
    "
  >
    <span
      class="
        text-[11px] font-black font-mono uppercase tracking-[0.4em] text-[#0a1d13]
      "
    >
      Boltaspá // System
    </span>
  </nav>

  <main
    class="
      w-full max-w-5xl flex-1 grid grid-cols-1 md:grid-cols-12 gap-12 py-24
      items-start
    "
  >

    <div class="md:col-span-7 space-y-8">
      <div class="space-y-3">
        <span
          class="
            text-[10px] font-black font-mono text-[#2d5a43] uppercase tracking-[0.3em] block
          "
        >
          <%= t("welcome.show.tagline") %>
        </span>
        <h1
          class="
            text-4xl md:text-5xl font-black uppercase tracking-tight text-[#0a1d13]
            leading-none
          "
        >
          <%= t("welcome.show.world_cup_title") %>
          <span class="block text-[#2d5a43] mt-1"><%= t("welcome.show.world_cup_subtitle") %></span>
        </h1>
      </div>

      <div class="flex items-center gap-8 pt-4">
        <%= link_to sign_up_path, class: "inline-flex items-center justify-between px-10 py-4 bg-[#2d5a43] text-white rounded-lg font-black text-[11px] uppercase tracking-widest hover:bg-[#0a1d13] transition-all group" do %>
          <span><%= t("welcome.show.start_predicting") %></span>
          <svg
            class="
              w-4 h-4 ml-4 transform group-hover:translate-x-1 transition-transform
            "
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        <% end %>

        <%= link_to t("welcome.show.sign_in"),
        new_session_path,
        class:
          "text-[11px] font-black font-mono text-slate-400 hover:text-[#0a1d13] uppercase tracking-widest transition-colors border-b border-transparent hover:border-[#0a1d13] pb-0.5" %>
      </div>
    </div>

    <div
      class="
        md:col-span-5 bg-white border border-gray-100 rounded-2xl p-8 shadow-sm
        space-y-6
      "
    >
      <div>
        <span
          class="
            text-[9px] font-black font-mono uppercase tracking-[0.2em] text-[#2d5a43] block
            mb-2
          "
        >
          <%= t("welcome.show.current_competition_label") %>
        </span>
        <h3 class="text-lg font-black uppercase tracking-tight text-[#0a1d13]">
          <%= t("welcome.show.world_cup_2026") %>
        </h3>
        <p class="text-xs font-bold text-slate-400 uppercase tracking-tight mt-1">
          <%= t("welcome.show.world_cup_description") %>
        </p>
      </div>

      <div class="pt-6 border-t border-gray-50">
        <span
          class="
            text-[9px] font-black font-mono uppercase tracking-[0.2em] text-slate-300 block
            mb-2
          "
        >
          <%= t("welcome.show.coming_soon_label") %>
        </span>
        <h3 class="text-lg font-black uppercase tracking-tight text-slate-300">
          <%= t("welcome.show.season_returns_title") %>
        </h3>
        <p class="text-xs font-bold text-slate-300 uppercase tracking-tight mt-1">
          <%= t("welcome.show.season_returns_description") %>
        </p>
      </div>
    </div>

  </main>

  <footer
    class="
      w-full max-w-5xl py-12 border-t border-gray-100 flex justify-between
      items-center opacity-40
    "
  >
    <span class="text-[9px] font-black font-mono uppercase tracking-[0.4em]">
      <%= t("welcome.show.footer") %>
    </span>
    <span class="text-[9px] font-black font-mono text-slate-300">
      v8.2.0 // PRO
    </span>
  </footer>

</div>
