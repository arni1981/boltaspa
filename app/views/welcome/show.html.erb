<div class="bg-[#f9faf9] min-h-screen text-[#0a1d13] flex flex-col items-center px-6 selection:bg-[#2d5a43] selection:text-white">

  <%# 1. SIMPLE BRANDING %>
  <nav class="w-full max-w-5xl py-16 flex justify-center md:justify-start">
    <span class="text-[12px] font-black uppercase tracking-[0.6em] border-b-2 border-[#0a1d13] pb-1">Boltaspá</span>
  </nav>

  <%# 2. THE HERO: THE MAIN EVENT %>
  <main class="flex-1 flex flex-col items-center justify-center text-center pb-24">
    <div class="max-w-4xl space-y-12">

      <div class="space-y-4">
        <h1 class="text-7xl md:text-9xl font-black uppercase tracking-tighter leading-[0.85]">
          <%= t('welcome.show.world_cup_title') %> <br>
          <span class="text-[#2d5a43]"><%= t('welcome.show.world_cup_subtitle') %></span>
        </h1>
        <p class="text-lg md:text-2xl font-bold uppercase tracking-tight text-slate-400 italic">
          <%= t('welcome.show.tagline') %>
        </p>
      </div>

      <div class="flex flex-col md:flex-row items-center justify-center gap-6 pt-6">
        <%= link_to t('welcome.show.start_predicting'), sign_up_path, class: "px-12 py-5 bg-[#0a1d13] text-white rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-[#2d5a43] transition-all active:scale-95 shadow-2xl shadow-[#0a1d13]/20" %>
        <%= link_to t('welcome.show.sign_in'), new_session_path, class: "text-[11px] font-black text-slate-400 hover:text-[#0a1d13] uppercase tracking-widest transition-colors" %>
      </div>
    </div>
  </main>

  <%# 3. THE "NEXT UP" INDICATOR (Clean & Minimal) %>
  <section class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-2 py-16 border-t border-gray-100 gap-12">
    <div>
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#2d5a43] block mb-4"><%= t('welcome.show.current_competition_label') %></span>
      <h3 class="text-xl font-black uppercase tracking-tight mb-2 text-[#0a1d13]"><%= t('welcome.show.world_cup_2026') %></h3>
      <p class="text-sm font-bold text-slate-400 uppercase tracking-tight"><%= t('welcome.show.world_cup_description') %></p>
    </div>

    <div class="md:text-right">
      <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-300 block mb-4"><%= t('welcome.show.coming_soon_label') %></span>
      <h3 class="text-xl font-black uppercase tracking-tight mb-2 text-slate-300"><%= t('welcome.show.season_returns_title') %></h3>
      <p class="text-sm font-bold text-slate-300 uppercase tracking-tight"><%= t('welcome.show.season_returns_description') %></p>
    </div>
  </section>

  <%# 4. FOOTER %>
  <footer class="py-12 opacity-30">
    <span class="text-[9px] font-black uppercase tracking-[0.6em]"><%= t('welcome.show.footer') %></span>
  </footer>

</div>
