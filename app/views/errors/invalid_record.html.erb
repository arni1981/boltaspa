<div class="max-w-2xl mx-auto">
  <div class="bg-white border border-gray-100 rounded-[2.5rem] shadow-sm overflow-hidden mb-5">
    <div class="px-10 py-6 border-b border-gray-50 bg-gray-50/30">
      <h3 class="text-[11px] font-black text-[#0a1d13] uppercase tracking-[0.3em]">
        <%= t('.title') %>
      </h3>
    </div>

    <div class="p-10">
      <div class="flex flex-col gap-4">
        <%# Grouped errors at the top of the card as per project guidelines %>
        <%= render 'layouts/flash_toasts' %>
      </div>
    </div>
  </div>
</div>
