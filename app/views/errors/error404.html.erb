<div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6">
  <h1 class="text-2xl font-black text-[#0a1d13] uppercase tracking-tighter mb-4">
    <%= t('.title') %>
  </h1>

  <p class="text-[11px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-10">
    <%= t('.description') %>
  </p>

  <%= link_to root_path, 
      class: "inline-flex items-center bg-[#2d5a43] text-white px-10 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest active:scale-95 transition-all shadow-lg shadow-emerald-900/10" do %>
    <%= t('.back_button') %>
  <% end %>
</div>
