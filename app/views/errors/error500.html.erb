<div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-6">
  <div class="mb-12">
    <%= image_tag 'media/illustrations/dozzy-1/10.png', 
        class: 'max-w-full max-h-[400px] object-contain opacity-90' %>
  </div>

  <h1 class="text-2xl font-black text-[#0a1d13] uppercase tracking-tighter mb-4">
    <%= t('.title') %>
  </h1>

  <p class="text-[11px] font-bold text-slate-400 uppercase tracking-[0.2em] mb-10 max-w-sm mx-auto leading-relaxed">
    <%= raw t('.description') %>
  </p>

  <%= link_to root_path, 
      class: "inline-flex items-center bg-[#0a1d13] text-white px-10 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest active:scale-95 transition-all shadow-lg" do %>
    <%= t('.back_button') %>
  <% end %>
</div>
