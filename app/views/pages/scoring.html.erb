<div class="max-w-2xl mx-auto py-24 px-8">

  <%# 1. THE HOOK %>
  <header class="mb-24">
    <h1 class="text-7xl font-black text-[#0a1d13] tracking-tighter leading-[0.85] mb-8">
      The Spirit<br>of the Game.
    </h1>
    <p class="text-xl text-slate-500 font-medium leading-relaxed max-w-lg">
      Our engine is a high-precision calculation. It rewards those who understand not just the winner, but the
      <span class="text-[#0a1d13] underline decoration-[#2d5a43] decoration-4 underline-offset-8">fundamental flow</span> of the 90 minutes.
    </p>
  </header>

  <%# 2. THE THREE TIERS %>
  <div class="space-y-16 mb-32">
    <%# TIER 1 %>
    <div class="group border-b-2 border-[#0a1d13] pb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-black text-[#0a1d13] uppercase tracking-tight">Perfect Sync</h2>
        <span class="text-4xl font-mono font-black text-[#2d5a43]">25</span>
      </div>
      <p class="text-slate-600 text-lg leading-snug">The Bullseye. Total synchronization with reality. There is no tax for perfection.</p>
    </div>

    <%# TIER 2 %>
    <div class="group border-b-2 border-slate-200 pb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-black text-[#0a1d13] uppercase tracking-tight">Correct Outcome</h2>
        <span class="text-4xl font-mono font-black text-[#0a1d13]">10 — 20</span>
      </div>
      <p class="text-slate-600 text-lg leading-snug">
        You called the winner. You start with <span class="font-bold text-[#0a1d13]">10 points</span>.
        Your accuracy bonus decays based on goal volume and goal difference errors.
      </p>
    </div>

    <%# TIER 3 %>
    <div class="group border-b-2 border-slate-100 pb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-black text-slate-300 uppercase tracking-tight">The Mercy Draw</h2>
        <span class="text-4xl font-mono font-black text-slate-200">1 — 4</span>
      </div>
      <p class="text-slate-500 text-lg leading-snug">You predicted a deadlock, but a winner emerged. A small reward for correctly identifying a tight contest.</p>
    </div>
  </div>

  <%# 3. INTERACTIVE SIMULATION: Reference Result 3-1 %>
  <section class="mb-32">
    <header class="flex items-center justify-between mb-12">
      <h3 class="text-[10px] font-black text-[#2d5a43] uppercase tracking-[0.4em]">Engine Benchmark</h3>
      <div class="flex items-center gap-3">
        <span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest">Actual Result</span>
        <span class="px-5 py-2 bg-[#0a1d13] text-white font-mono font-black text-lg rounded-2xl shadow-xl shadow-midnight/20">3 - 1</span>
      </div>
    </header>

    <div class="space-y-4">
      <% [
        { guess: "3 - 1", pts: 25, label: "Perfect Sync", desc: "No penalties apply." },
        { guess: "2 - 0", pts: 17, label: "Outcome Match", desc: "-4 goal dist / -2 GD error." },
        { guess: "4 - 2", pts: 16, label: "Outcome Match", desc: "-4 goal dist / 0 GD error." },
        { guess: "5 - 0", pts: 10, label: "Base Outcome", desc: "Decay hit the floor." },
        { guess: "1 - 1", pts: 2,  label: "Mercy Draw", desc: "Correct on the tight spread." },
        { guess: "0 - 1", pts: 0,  label: "Incorrect", desc: "Wrong winner." }
      ].each do |ex| %>
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 flex items-center justify-between group transition-all duration-500">
          <div class="flex flex-col">
            <span class="text-[9px] font-bold text-slate-300 uppercase tracking-widest mb-2">Predicted</span>
            <div class="flex items-baseline gap-4">
              <span class="text-4xl font-black text-[#0a1d13] tracking-tighter"><%= ex[:guess] %></span>
              <span class="text-xs font-medium text-slate-400 italic"><%= ex[:desc] %></span>
            </div>
          </div>
          <div class="text-right">
             <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest block mb-1"><%= ex[:label] %></span>
             <span class="text-5xl font-mono font-black tracking-tighter <%= ex[:pts] == 25 ? 'text-[#2d5a43]' : 'text-[#0a1d13]' %> <%= 'opacity-20' if ex[:pts] == 0 %>">
               +<%= ex[:pts] %>
             </span>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# 4. TECHNICAL SPECIFICATION %>
  <section class="pt-20 border-t border-slate-100">
    <div class="bg-[#0a1d13] p-12 rounded-[3.5rem] shadow-2xl relative overflow-hidden">
      <div class="flex items-center gap-3 mb-10">
        <div class="w-2.5 h-2.5 rounded-full bg-[#2d5a43]"></div>
        <span class="text-[10px] font-mono text-white/40 uppercase tracking-[0.3em]">proximity_v9_stable.sql</span>
      </div>

      <div class="prose prose-invert max-w-none">
        <p class="text-white/60 text-sm leading-relaxed mb-8">
          We have achieved <span class="text-white font-bold">Mathematical Symmetry</span>.
          Whether you predict a winner in a draw or a draw in a winning game, the
          <span class="text-[#2d5a43]">Proximity Reward</span> calculates your points based
          strictly on the total goal distance.
        </p>

        <div class="bg-black/40 rounded-2xl p-8 font-mono text-[13px] text-[#2d5a43] leading-relaxed">
          <span class="text-white/30">-- Symmetrical Mercy Logic</span><br>
          <span class="text-white">IF</span> outcome_missed <span class="text-white">THEN</span><br>
          &nbsp;&nbsp;<span class="text-white">RETURN</span> max(0, 4 - total_goal_distance);
        </div>
      </div>

      <div class="mt-12 pt-10 border-t border-white/5 text-center">
        <span class="text-lg font-mono text-white/80">
          $$ P_{miss} = \max(0, 4 - \sum |p_i - r_i|) $$
        </span>
      </div>
    </div>
  </section>
</div>
