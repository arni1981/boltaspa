<%# locals: (title:, subtitle:, breadcrumbs: [], crest: nil) %>

<div class="mb-12">
  <nav class="flex items-center gap-2 mb-6">
    <% breadcrumbs.each_with_index do |crumb, index| %>
      <% if index > 0 %><span class="text-[10px] text-gray-300">/</span><% end %>
      <%= crumb[:path] ? link_to(crumb[:name], crumb[:path], class: "text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-[#2d5a43] transition-colors") : content_tag(:span, crumb[:name], class: "text-[10px] font-black text-[#2d5a43] uppercase tracking-widest") %>
    <% end %>
  </nav>

  <div class="flex items-center gap-6">
    <% if crest.present? %>
      <div class="w-16 h-16 bg-white border border-gray-100 rounded-2xl p-3 shadow-sm shrink-0">
        <%= image_tag crest, class: "w-full h-full object-contain opacity-90", alt: title %>
      </div>
    <% end %>

    <div>
      <h1 class="text-4xl font-black text-[#0a1d13] tracking-tighter uppercase leading-none mb-2">
        <%= title %>
      </h1>
      <p class="text-[11px] font-black text-gray-400 uppercase tracking-[0.3em]">
        <%= subtitle %>
      </p>
    </div>
  </div>
</div>
