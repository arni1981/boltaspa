<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      /* Base Reset & Core Styles */
      body {
        background-color: #f9faf9;
        font-family: -apple-system, system-ui, sans-serif;
        margin: 0; padding: 40px 20px;
      }
      .wrapper {
        max-width: 500px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #eeeeee;
        border-radius: 24px;
        padding: 40px;
        text-align: center;
      }
      .logo-mark {
        background-color: #0a1d13;
        color: #ffffff !important;
        width: 40px; height: 40px; line-height: 40px;
        border-radius: 10px;
        display: inline-block;
        font-weight: 900;
        margin-bottom: 24px;
        text-decoration: none;
      }
      .btn-pro {
        background-color: #2d5a43;
        color: #ffffff !important;
        text-decoration: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        display: inline-block;
      }
      p { color: #4b5563; font-size: 14px; line-height: 1.6; }
      h1 { color: #0a1d13; font-size: 18px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <a href="<%= root_url %>" class="logo-mark">Boltaspá.is</a>
      <%= yield %>
    </div>
  </body>
</html>
