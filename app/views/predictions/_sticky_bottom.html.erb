<%# locals: (upcoming_matches:, predictions_map:, unfinished_matches:) %>

<div id="sticky_bottom" class="fixed bottom-8 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none transition-all">
  <div class="pointer-events-auto bg-[#0a1d13] border border-white/10 shadow-[0_25px_60px_rgba(0,0,0,0.4)] rounded-[2.5rem] p-2 flex items-center gap-2">

    <div class="flex flex-col pl-6 pr-6 min-w-50">
      <div class="flex items-center gap-2 mb-1">
        <%# Industrial Status Dot %>
        <div class="w-1.5 h-1.5 rounded-full <%= unfinished_matches.any? ? 'bg-amber-400' : 'bg-[#2d5a43]' %>"></div>

        <span class="text-[9px] font-black <%= unfinished_matches.any? ? 'text-amber-400' : 'text-[#2d5a43]' %> uppercase tracking-widest">
          <%= unfinished_matches.any? ? t('predictions.sticky_bottom.remaining', count: unfinished_matches.count) : t('predictions.sticky_bottom.all_ready') %>
        </span>
      </div>

      <div class="flex gap-2">
        <% if unfinished_matches.any? %>
          <% unfinished_matches.first(3).each do |match| %>
            <a href="#<%= dom_id(match) %>" data-turbo="false" class="text-[9px] font-black text-white/40 bg-white/5 px-2 py-1 rounded hover:bg-white/20 hover:text-white transition-all uppercase">
              <%= match.home_team.tla %> <%= match.away_team.tla %>
            </a>
          <% end %>
        <% else %>
          <span class="text-[9px] font-black text-white/20 uppercase tracking-[0.2em]"><%= t('predictions.sticky_bottom.all_ready') %></span>
        <% end %>
      </div>
    </div>
  </div>
</div>
