<% @updated_match_ids.each do |match_id| %>
  <%= turbo_stream.replace "match_#{match_id}" do %>
    <%= render "match_row", 
                match: @matches_indexed[match_id], 
                prediction: @predictions_map[match_id],
                is_updated: true %>
  <% end %>
<% end %>

<% @errors.each do |prediction| %>
  <% match_id = prediction.match_id %>

  <%= turbo_stream.replace "match_#{match_id}" do %>
    <%= render "match_row", 
                match: @matches_indexed[match_id], 
                prediction: prediction,
                error: true %>
  <% end %>
<% end %>
