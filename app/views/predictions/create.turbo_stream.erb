<%= turbo_stream.replace dom_id(@match) do %>
  <%= render "match_row", 
              match: @match, 
              prediction: @predictions_map[@match.id],
              is_updated: true %>
<% end %>

<%= turbo_stream.replace "sticky_bottom" do %>
  <%= render "sticky_bottom", 
    predictions_map: @predictions_map, 
    upcoming_matches: @upcoming_matches,
    unfinished_matches: @unfinished_matches %>
<% end %>
