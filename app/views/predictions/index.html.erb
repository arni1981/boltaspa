<%# app/views/predictions/index.html.erb %>

<%= render 'layouts/shared/page_header', 
    title: t('.page_title'), 
    breadcrumbs: [{ name: t('common.home'), path: root_path }, { name: t('.breadcrumb_current') }] %>

<%= form_with url: predictions_path do |f| %>
  <%# Grunnurinn: Tvær hreinar hlustanir á öll skjöl %>
  <div class="max-w-6xl pb-48 px-4 mx-auto"
       data-controller="predictions-keyboard"
       data-action="
        keydown@document->predictions-keyboard#handleKeydown:prevent
        keydown.down@document->predictions-keyboard#handleForward:prevent
        keydown.right@document->predictions-keyboard#handleForward:prevent
        keydown.left@document->predictions-keyboard#handleBackwards:prevent
        keydown.up@document->predictions-keyboard#handleBackwards:prevent
        click->predictions-keyboard#handleRowClick">

    <%# Flokkað eftir dögum %>
    <% @upcoming_matches.group_by { |m| m.kickoff_at.to_date }.each do |date, matches| %>

      <div class="mb-4 mt-10 px-2 flex items-center justify-between">
        <h3 class="text-[13px] font-bold text-slate-400 tracking-tight">
          <%= l(date, format: "%A %d. %B") %>
        </h3>
        <div class="h-px bg-slate-100 flex-1 ml-6"></div>
      </div>

      <%# 2-dálka útlit %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 isolate">
          <% matches.each do |match| %>
            <%= render 'match_row', 
                        match: match, 
                        prediction: @predictions_map[match.id] %>
          <% end %>
      </div>
    <% end %>
  </div>

  <%# STICKY BOTTOM ACTIONS %>
  <div id="sticky_bottom" class="fixed bottom-8 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none transition-all">
    <div class="pointer-events-auto bg-[#0a1d13] border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)] rounded-2xl p-1.5 flex items-center justify-center min-w-[220px] h-[64px] shrink-0">

      <%= f.button data: { turbo_submits_with: 'Vista ...' }, class: "inline-flex items-center justify-between w-full h-full px-10 bg-[#2d5a43] text-white rounded-xl font-bold text-[13px] hover:bg-[#1a3f2d] transition-all group active:scale-95 whitespace-nowrap" do %>
        <span>Vista spár</span>
        <svg class="w-4 h-4 ml-4 transform group-hover:translate-x-1 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      <% end %>

    </div>
  </div>
<% end %>
