<%# app/views/predictions/_match_row.html.erb %>
<%# locals: (match:, prediction:, is_updated: false, error: nil) -%>

<div
  id="<%= dom_id(match) %>"
  class="relative bg-white border border-slate-100 rounded-2xl p-4 transition-all select-none <%= 'opacity-60' unless match.predictable? %> <%= 'is-success-pulse' if is_updated %> match-row"
>

  <%# Clean grouped validation errors at the top level of the card %>
  <% if error %>
    <div class="absolute inset-x-0 -top-3 flex justify-center z-20 pointer-events-none">
      <span class="bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-lg shadow-lg animate-fade-in whitespace-nowrap">
        <%= prediction.errors.full_messages.to_sentence %>
      </span>
    </div>
  <% end %>

  <div class="space-y-4">

    <%# METADATA TIMING ROW %>
    <div class="flex items-center justify-between pb-1 border-b border-slate-50">
      <span class="text-[10px] font-bold font-mono text-slate-300">
        <%= match.predictable? ? l(match.kickoff_at, format: :only_time) : t('.locked_status', default: 'LÆST') %>
      </span>
      <% unless match.predictable? %>
        <span class="text-[10px] font-bold font-mono text-red-500 bg-red-50 px-2 py-0.5 rounded-md">
          <%= t('.locked_label', default: 'Læst') %>
        </span>
      <% end %>
    </div>

    <%# HOME TEAM TOUCH SECTOR %>
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center p-1.5 shrink-0 shadow-sm">
          <% if match.home_team.crest_url.present? %>
            <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain #{'grayscale opacity-50' unless match.predictable?}" %>
          <% end %>
        </div>
        <div class="text-[13px] font-bold text-[#0a1d13] leading-none truncate">
          <%= localized_short_name(match.home_team) %>
        </div>
      </div>

      <div class="flex gap-1.5">
        <% (0..5).each do |score| %>
          <% selected = prediction&.home_guess == score %>
          <label class="cursor-pointer">
            <input
              type="radio"
              name="predictions[<%= match.id %>][home_guess]"
              value="<%= score %>"
              class="sr-only peer"
              <%= 'checked' if selected %>
              <%= 'disabled' unless match.predictable? %>
            >
            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-xs font-bold font-mono transition-all border bg-slate-50 text-slate-400 border-slate-100 peer-checked:bg-[#0a1d13] peer-checked:text-white peer-checked:border-[#0a1d13] hover:text-slate-600">
              <%= score %>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <%# AWAY TEAM TOUCH SECTOR %>
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-9 h-9 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center p-1.5 shrink-0 shadow-sm">
          <% if match.away_team.crest_url.present? %>
            <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain #{'grayscale opacity-50' unless match.predictable?}" %>
          <% end %>
        </div>
        <div class="text-[13px] font-bold text-[#0a1d13] leading-none truncate">
          <%= localized_short_name(match.away_team) %>
        </div>
      </div>

      <div class="flex gap-1.5">
        <% (0..5).each do |score| %>
          <% selected = prediction&.away_guess == score %>
          <label class="cursor-pointer">
            <input
              type="radio"
              name="predictions[<%= match.id %>][away_guess]"
              value="<%= score %>"
              class="sr-only peer"
              <%= 'checked' if selected %>
              <%= 'disabled' unless match.predictable? %>
            >
            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-xs font-bold font-mono transition-all border bg-slate-50 text-slate-400 border-slate-100 peer-checked:bg-[#38bdf8] peer-checked:text-white peer-checked:border-[#38bdf8] hover:text-slate-600">
              <%= score %>
            </div>
          </label>
        <% end %>
      </div>
    </div>

  </div>
</div>
