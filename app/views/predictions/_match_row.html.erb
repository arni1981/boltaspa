<%# locals: (match:, prediction:, is_updated: false) -%>
<% current_val = prediction ? "#{prediction.home_guess}-#{prediction.away_guess}" : "" %>

<%= form_with url: predictions_path, method: :post, id: "#{dom_id(match)}", 
  data: {controller: 'auto-submit', action: 'turbo:submit-end->auto-submit#pulse'} do |f| %>
  <%= f.hidden_field :match_id, value: match.id %>

  <div class="match-row min-h-[5.5rem] px-3 md:px-10 flex items-center transition-colors group relative bg-white">
    <!-- HOME: Right-aligned, shrinks to accommodate center -->
    <div class="flex-1 flex items-center justify-end gap-2 md:gap-4 min-w-0">
      <span class="md:hidden text-[11px] font-black uppercase text-[#0a1d13] tracking-tight leading-none">
        <%= match.home_team.tla %>
      </span>
      <span class="hidden md:block text-[13px] font-black uppercase text-[#0a1d13] tracking-tight truncate leading-none">
        <%= match.home_team.short_name %>
      </span>
      <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-50 rounded-xl flex items-center justify-center p-1.5 shrink-0 border border-gray-100 shadow-sm">
        <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" if match.home_team.crest_url.present? %>
      </div>
    </div>

    <!-- CENTER: Tightened for Mobile -->
    <div class="w-20 md:w-48 flex flex-col items-center gap-1 mx-2 md:mx-4 shrink-0">
      <span class="text-[8px] md:text-[9px] font-black font-mono text-slate-300 uppercase tracking-widest">
        <%= l match.kickoff_at, format: :only_time %>
      </span>
      <div class="relative w-full">
        <select name="score_string"
                data-action="auto-submit#submit"
                class="w-full h-9 md:h-12 bg-gray-50 border-0 rounded-lg md:rounded-2xl text-center font-mono text-xs md:text-sm font-black appearance-none text-[#0a1d13] focus:ring-2 focus:ring-[#2d5a43] transition-all cursor-pointer px-0">
          <option value="">-</option>
          <%= score_group_options(current_val) %>
        </select>
      </div>
    </div>

    <!-- AWAY: Left-aligned, mirrors Home -->
    <div class="flex-1 flex items-center justify-start gap-2 md:gap-4 min-w-0">
      <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-50 rounded-xl flex items-center justify-center p-1.5 shrink-0 border border-gray-100 shadow-sm">
        <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" if match.away_team.crest_url.present? %>
      </div>
      <span class="md:hidden text-[11px] font-black uppercase text-[#0a1d13] tracking-tight leading-none">
        <%= match.away_team.tla %>
      </span>
      <span class="hidden md:block text-[13px] font-black uppercase text-[#0a1d13] tracking-tight truncate leading-none">
        <%= match.away_team.short_name %>
      </span>
    </div>

  </div>
<% end %>
