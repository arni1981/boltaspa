<%# locals: (match:, prediction:, is_updated: false) -%>
<% current_val = prediction ? "#{prediction.home_guess}-#{prediction.away_guess}" : "" %>

<div id="<%= dom_id(match) %>" 
     class="match-row h-22 px-8 flex items-center transition-colors group relative bg-white
            <%= 'is-success-pulse' if is_updated %>">

  <div class="w-1/3 flex items-center gap-4">
    <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center p-1.5 shrink-0 border border-gray-100 shadow-sm">
      <%= image_tag match.home_team.crest_url, class: "w-full h-full object-contain" if match.home_team.crest_url.present? %>
    </div>
    <span class="text-[13px] font-black uppercase text-[#0a1d13] tracking-tight truncate">
      <%= match.home_team.short_name %>
    </span>
  </div>

  <div class="w-48 flex flex-col items-center gap-1 mx-auto">
    <span class="text-[9px] font-black font-mono text-slate-300 uppercase tracking-[0.2em]">
      <%= match.kickoff_at.strftime("%H:%M") %>
    </span>
    <div class="relative w-full">
      <select name="predictions[<%= match.id %>][score_string]"
              class="w-full h-12 bg-gray-50 border-0 rounded-2xl text-center font-mono text-sm font-black appearance-none text-[#0a1d13] focus:ring-2 focus:ring-[#2d5a43] transition-all cursor-pointer">
        <option value="">-</option>
        <%= score_group_options(current_val) %>
      </select>
    </div>
  </div>

  <div class="w-1/3 flex items-center justify-end gap-4 text-right">
    <span class="text-[13px] font-black uppercase text-[#0a1d13] tracking-tight truncate">
      <%= match.away_team.short_name %>
    </span>
    <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center p-1.5 shrink-0 border border-gray-100 shadow-sm">
      <%= image_tag match.away_team.crest_url, class: "w-full h-full object-contain" if match.away_team.crest_url.present? %>
    </div>
  </div>
</div>
