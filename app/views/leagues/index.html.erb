<%= render 'layouts/shared/page_header',
  title: t('.title'),
  subtitle: t('.subtitle'),
  breadcrumbs: [{ name: t('common.home'), path: root_path }, { name: t('.breadcrumb_current') }] %>

<div class="max-w-2xl mx-auto pb-48 px-4">
  <div class="divide-y divide-gray-100 bg-white rounded-4xl border border-gray-100 shadow-sm overflow-hidden">
    <% @leagues.each do |league| %>
      <%= link_to league_path(league), class: "flex items-center justify-between p-6 hover:bg-gray-50 transition-colors active:bg-gray-100" do %>
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-[#0a1d13] rounded-xl flex items-center justify-center text-white text-xs font-black"><%= league.name.first.upcase %></div>
          <span class="text-sm font-black text-[#0a1d13] uppercase tracking-tight"><%= league.name %></span>
        </div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" />
        </svg>
      <% end %>
    <% end %>
  </div>

  <div class="mt-8 flex gap-4">
    <%= link_to new_league_path, class: "flex-1 text-center py-4 border border-gray-200 rounded-2xl text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-[#2d5a43] hover:border-[#2d5a43] transition-all" do %>
      <%= t('.create_button') %>
    <% end %>

    <%= link_to join_league_path, class: "flex-1 text-center py-4 border border-gray-200 rounded-2xl text-[10px] font-black text-gray-400 uppercase tracking-widest hover:text-[#2d5a43] hover:border-[#2d5a43] transition-all" do %>
      <%= t('.find_button') %>
    <% end %>
  </div>
</div>
