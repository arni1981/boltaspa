<%= render 'layouts/shared/page_header',
  title: t('.title'),
  subtitle: t('.subtitle'),
  breadcrumbs: [{ name: t('common.home'), path: root_path }, { name: t('.breadcrumb_current') }] %>

<div class="max-w-2xl pb-32">
  <%= form_with model: @league, class: "space-y-8" do |f| %>
    <%= render 'layouts/error_messages' %>

    <section class="bg-white border border-gray-200 rounded-3xl shadow-sm overflow-hidden">
      <header class="px-8 py-5 border-b border-gray-100 bg-[#0a1d13] flex items-center justify-between">
        <h2 class="text-[11px] font-black text-gray-300 uppercase tracking-[0.2em]"><%= t('.section_title') %></h2>
      </header>

      <div class="p-8 md:p-10 space-y-10">
        <div>
          <%= f.label :name, t('.name_label'), class: "block text-[11px] font-black text-gray-400 uppercase tracking-[0.2em] mb-4" %>
          <%= f.text_field :name,
            placeholder: t('.name_placeholder'),
            class: "w-full bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-[#2d5a43] focus:border-transparent text-xl font-black text-[#0a1d13] px-6 py-5 transition-all placeholder:text-gray-200" %>

          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-[9px] font-bold text-gray-300 uppercase tracking-widest self-center mr-2"><%= t('.suggestions_label') %></span>
            <% [t('.suggestion_1'), t('.suggestion_2'), t('.suggestion_3')].each do |suggestion| %>
              <button type="button" class="text-[10px] font-black text-gray-500 bg-gray-100 px-4 py-2 rounded-lg hover:bg-[#2d5a43] hover:text-white transition-all cursor-pointer uppercase tracking-wider">
                <%= suggestion %>
              </button>
            <% end %>
          </div>
        </div>

        <div class="p-6 bg-[#f9faf9] border border-gray-100 rounded-2xl flex items-start gap-5">
          <div class="w-10 h-10 bg-white rounded-xl border border-gray-100 flex items-center justify-center shrink-0 shadow-sm">
            <svg class="w-5 h-5 text-[#2d5a43]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>

          <div>
            <h4 class="text-[13px] font-black text-[#0a1d13] uppercase tracking-tight mb-1"><%= t('.info_title') %></h4>
            <p class="text-sm text-gray-500 leading-relaxed">
              <%= t('.info_text') %>
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="flex items-center justify-between pt-4">
      <%= link_to t('.cancel_link'), root_path, class: "text-[11px] font-bold text-gray-400 hover:text-gray-600 uppercase tracking-widest transition-colors" %>

      <button type="submit" class="bg-[#2d5a43] text-white px-12 py-5 rounded-2xl font-bold text-sm hover:bg-[#1e3f2e] transition-all active:scale-95 flex items-center gap-4 shadow-xl shadow-[#2d5a43]/20">
        <span><%= t('.submit_button') %></span>
        <svg class="w-5 h-5 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </button>
    </div>
  <% end %>
</div>
