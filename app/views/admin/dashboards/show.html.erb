<div class="p-10 font-mono text-[13px] text-[#0a1d13] bg-[#f9faf9] min-h-screen selection:bg-[#2d5a43] selection:text-white">

  <%# --- 01. HEADER --- %>
  <header class="mb-16 border-b-2 border-[#0a1d13] pb-8 flex justify-between items-end">
    <div>
      <div class="text-[11px] font-black uppercase tracking-[0.4em] text-slate-400 mb-2">System // Administration</div>
      <h1 class="text-4xl font-black uppercase tracking-tighter">Boltaspá Dashboard</h1>
    </div>
    <div class="text-right">
      <div class="text-[11px] font-black uppercase text-slate-400 italic">Server Time</div>
      <div class="font-bold"><%= l Time.current, format: "%Y-%m-%d // %H:%M:%S" %></div>
    </div>
  </header>

  <%# --- 02. KPI SUMMARY --- %>
  <div class="grid grid-cols-4 gap-4 mb-16">
    <% @stats.each do |label, value| %>
      <div class="border border-gray-200 bg-white p-6 shadow-sm">
        <div class="text-gray-400 uppercase mb-2 text-[11px] font-black tracking-widest"><%= label.to_s.humanize %></div>
        <div class="text-3xl font-black"><%= value %></div>
      </div>
    <% end %>
  </div>

  <%# --- 03. TOP PREDICTORS --- %>
  <div class="mb-16">
    <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-blue-600">Top Predictors</h2>
    <div class="grid grid-cols-5 gap-4">
      <% @top_predictors.each do |user| %>
        <div class="bg-white border border-gray-100 p-6">
          <div class="font-black truncate mb-2 uppercase text-[12px]"><%= user.name %></div>
          <div class="text-3xl font-black text-[#2d5a43] tracking-tighter"><%= user.predictions_count %></div>
          <div class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Total Predictions</div>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- 04. ACTIVITY LOGS --- %>
  <div class="grid grid-cols-3 gap-16 mb-16">
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#2d5a43]">Latest Sign-ups</h2>
      <% @latest_users.each do |user| %>
        <div class="flex justify-between py-3 border-b border-gray-100">
          <span class="font-bold"><%= user.name %></span>
          <span class="text-gray-400"><%= time_ago_in_words(user.created_at) %> ago</span>
        </div>
      <% end %>
    </div>

    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#2d5a43]">Latest Visits</h2>
      <% @latest_visits.each do |visit| %>
        <div class="flex justify-between py-3 border-b border-gray-100">
          <span class="font-bold"><%= visit.user.name %></span>
          <span class="text-gray-400"><%= time_ago_in_words(visit.created_at) %> ago</span>
        </div>
      <% end %>
    </div>

    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#2d5a43]">Latest Leagues</h2>
      <% @latest_leagues.each do |league| %>
        <div class="flex justify-between py-3 border-b border-gray-100">
          <span class="font-bold uppercase"><%= league.name %></span>
          <span class="text-gray-400"><%= league.members.count %> members</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- 05. SYSTEM INSPECTION (Cache & Jobs) --- %>
  <div class="grid grid-cols-2 gap-16 mb-16">

    <%# CACHE KEYS LIST %>
    <div>
      <div class="flex justify-between items-end mb-4 border-b border-[#0a1d13] pb-2 text-orange-600">
        <h2 class="font-black uppercase">Cache Inspector</h2>
        <span class="text-[11px] font-bold uppercase tracking-widest"><%= @system_stats[:cache_size_mb] %> MB Est.</span>
      </div>
      <% if @latest_cache_entries.any? %>
        <% @latest_cache_entries.each do |entry| %>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="truncate max-w-[320px] text-gray-600"><%= entry.key %></span>
            <span class="text-gray-300 text-[11px] uppercase"><%= time_ago_in_words(entry.created_at) %></span>
          </div>
        <% end %>
      <% else %>
        <div class="py-4 text-red-500 italic">No cache keys found in database.</div>
      <% end %>
    </div>

    <%# JOB FREQUENCY LIST %>
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-purple-600">Most Run Jobs</h2>
      <% if @job_frequency.any? %>
        <% @job_frequency.each do |job_class, count| %>
          <div class="flex justify-between py-2 border-b border-gray-100">
            <span class="font-bold uppercase tracking-tight"><%= job_class.delete_suffix('Job') %></span>
            <span class="font-black"><%= count %></span>
          </div>
        <% end %>
      <% else %>
        <div class="py-4 text-red-500 italic">No job history found in database.</div>
      <% end %>
    </div>
  </div>

  <%# --- 06. PENDING QUEUE TERMINAL --- %>
  <div>
    <div class="flex justify-between items-end mb-4 border-b border-[#0a1d13] pb-2 text-emerald-600">
      <h2 class="font-black uppercase">Pending Queue Backlog</h2>
      <span class="text-[11px] font-bold uppercase tracking-widest"><%= @system_stats[:queue_backlog] %> Active</span>
    </div>
    <table class="w-full text-left">
      <thead>
        <tr class="text-gray-400 uppercase text-[11px] font-black">
          <th class="py-3">ID</th>
          <th class="py-3">Class</th>
          <th class="py-3 text-right">Age</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @active_jobs.each do |job| %>
          <tr>
            <td class="py-3">#<%= job.id %></td>
            <td class="py-3 font-bold uppercase"><%= job.class_name %></td>
            <td class="py-3 text-right text-gray-400"><%= time_ago_in_words(job.created_at) %></td>
          </tr>
        <% end %>
        <% if @active_jobs.empty? %>
          <tr><td colspan="3" class="py-12 text-center text-gray-300 uppercase italic tracking-widest">Queue Clear</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <footer class="mt-32 pt-8 border-t border-gray-100 text-center opacity-30 italic">
    End of dashboard.
  </footer>

</div>
