<h1 class="text-xl font-black uppercase text-[#0a1d13] tracking-tight mb-8">
  Kerfisstjórnborð
</h1>

<%# --- KPI GRID --- %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
  <% @stats.each do |key, val| %>
    <div class="bg-white border border-slate-100 p-4 rounded-xl shadow-2xs font-mono">
      <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block">
        <%= key.to_s.humanize %>
      </span>
      <span class="text-xl font-black text-[#0a1d13] block mt-1">
        <%= val %>
      </span>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
  
  <%# --- LEAGUES CONSOLE --- %>
  <section class="space-y-3">
    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest px-1">
      Topp 10 Deildir
    </h2>
    
    <div class="bg-white border border-slate-100 rounded-xl divide-y divide-slate-50 overflow-hidden shadow-sm text-[13px]">
      <% @mega_leagues.each do |league| %>
        <div class="p-4 flex flex-col gap-1.5">
          <div class="flex items-center justify-between">
            <span class="font-bold text-[#0a1d13]"><%= league.name %></span>
            <span class="font-mono text-xs text-[#2d5a43] font-bold bg-emerald-50 px-2 py-0.5 rounded">
              <%= league.users_count %> meðlimir
            </span>
          </div>
          
          <div class="text-[11px] text-slate-400 leading-relaxed font-medium">
            <span class="text-slate-300 mr-1">Meðlimir:</span>
            <%= league.members.map(&:name).join(", ") %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# --- USERS LEDGER --- %>
  <section class="space-y-3">
    <h2 class="text-xs font-black text-slate-400 uppercase tracking-widest px-1">
      Nýjustu Notendur
    </h2>
    
    <div class="bg-white border border-slate-100 rounded-xl divide-y divide-slate-50 overflow-hidden shadow-sm text-[13px]">
      <% @latest_users.each do |user| %>
        <div class="p-4 flex flex-col gap-2">
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <span class="font-bold text-[#0a1d13] block truncate"><%= user.name %></span>
              <span class="text-[10px] font-mono text-slate-400 block mt-0.5">
                <%= l(user.created_at, format: "%d. %b %H:%M") %>
              </span>
            </div>
            
            <div class="shrink-0 text-right">
              <span class="font-mono text-xs font-black text-[#0a1d13] bg-slate-50 border border-slate-100 px-2 py-1 rounded-lg">
                <%= user.predictions.count %> spár
              </span>
            </div>
          </div>

          <% if user.leagues.any? %>
            <div class="flex flex-wrap gap-1 items-center">
              <% user.leagues.each do |lg| %>
                <span class="text-[10px] font-mono font-medium bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">
                  <%= lg.name %>
                </span>
              <% end %>
            </div>
          <% else %>
            <span class="text-[11px] italic text-slate-300 block">Engir hópar skráðir</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>
  
</div>
