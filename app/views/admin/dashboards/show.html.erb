<div class="p-10 font-mono text-[11px] text-[#0a1d13] bg-[#f9faf9] min-h-screen">

  <%# --- 01. KPI SUMMARY --- %>
  <div class="grid grid-cols-4 gap-4 mb-16">
    <% @stats.each do |label, value| %>
      <div class="border border-gray-200 bg-white p-6">
        <div class="text-gray-400 uppercase mb-2"><%= label %></div>
        <div class="text-2xl font-black"><%= value %></div>
      </div>
    <% end %>
  </div>

  <%# --- 02. TOP PREDICTORS (Restored) --- %>
  <div class="mb-16">
    <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-blue-600">Top Predictors</h2>
    <div class="grid grid-cols-5 gap-4">
      <% @top_predictors.each do |user| %>
        <div class="bg-white border border-gray-100 p-4">
          <div class="font-black truncate mb-1"><%= user.name %></div>
          <div class="text-xl font-black text-[#2d5a43]"><%= user.predictions_count %></div>
          <div class="text-[9px] text-gray-400 uppercase">Predictions</div>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- 03. ACTIVITY LOGS --- %>
  <div class="grid grid-cols-2 gap-16 mb-16">
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#2d5a43]">Latest Users</h2>
      <% @latest_users.each do |user| %>
        <div class="flex justify-between py-1 border-b border-gray-100">
          <span><%= user.name %></span>
          <span class="text-gray-400 text-[10px]"><%= time_ago_in_words(user.created_at) %></span>
        </div>
      <% end %>
    </div>

    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#2d5a43]">Latest Leagues</h2>
      <% @latest_leagues.each do |league| %>
        <div class="flex justify-between py-1 border-b border-gray-100">
          <span class="font-bold"><%= league.name %></span>
          <span class="text-gray-400"><%= league.members.count %> members</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- 04. SYSTEM INSPECTION --- %>
  <div class="grid grid-cols-2 gap-16 mb-16">

    <%# CACHE KEYS LIST %>
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-orange-600">Cache Inspector (<%= @system_stats[:cache_size_mb] %> MB)</h2>
      <% if @latest_cache_entries.any? %>
        <% @latest_cache_entries.each do |entry| %>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span class="truncate max-w-[300px]"><%= entry.key %></span>
            <span class="text-gray-300 text-[9px] uppercase"><%= time_ago_in_words(entry.created_at) %></span>
          </div>
        <% end %>
      <% else %>
        <div class="py-4 text-red-500 italic">No cache keys found</div>
      <% end %>
    </div>

    <%# JOB FREQUENCY LIST %>
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-purple-600">Most Run Jobs</h2>
      <% if @job_frequency.any? %>
        <% @job_frequency.each do |job_class, count| %>
          <div class="flex justify-between py-1 border-b border-gray-100">
            <span><%= job_class %></span>
            <span class="font-black"><%= count %></span>
          </div>
        <% end %>
      <% else %>
        <div class="py-4 text-red-500 italic">No job history found</div>
      <% end %>
    </div>
  </div>

  <%# --- 05. PENDING QUEUE --- %>
  <div>
    <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-emerald-600">Pending Queue (<%= @system_stats[:queue_backlog] %>)</h2>
    <table class="w-full text-left">
      <thead>
        <tr class="text-gray-400 uppercase text-[10px]">
          <th class="py-2">ID</th>
          <th class="py-2">Class</th>
          <th class="py-2 text-right">Age</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @active_jobs.each do |job| %>
          <tr>
            <td class="py-2">#<%= job.id %></td>
            <td class="py-2 font-bold"><%= job.class_name %></td>
            <td class="py-2 text-right text-gray-400"><%= time_ago_in_words(job.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>
