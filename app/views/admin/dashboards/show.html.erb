<%# app/views/admin/dashboards/show.html.erb %>
<div class="p-10 font-mono text-[13px] text-[#0a1d13] bg-[#f9faf9] min-h-screen selection:bg-[#2d5a43] selection:text-white">

  <%# --- 01. HEADER --- %>
  <header class="mb-16 border-b-2 border-[#0a1d13] pb-8 flex justify-between items-end">
    <div>
      <div class="text-[11px] font-black uppercase tracking-[0.4em] text-slate-400 mb-2">System // Administration</div>
      <h1 class="text-4xl font-black uppercase tracking-tighter">Boltaspá Dashboard</h1>
    </div>
    <div class="text-right">
      <div class="text-[11px] font-black uppercase text-slate-400 italic">Server Time</div>
      <div class="font-bold"><%= l Time.current, format: "%Y-%m-%d // %H:%M:%S" %></div>
    </div>
  </header>

  <%# --- 02. KPI SUMMARY --- %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-16">
    <% @stats.each do |label, value| %>
      <div class="border border-slate-200/60 bg-white p-6 rounded-xl shadow-sm">
        <div class="text-slate-400 uppercase mb-2 text-[11px] font-black tracking-widest"><%= label.to_s.humanize %></div>
        <div class="text-3xl font-black text-[#0a1d13] tracking-tight"><%= number_with_delimiter(value) %></div>
      </div>
    <% end %>
  </div>

  <%# --- 03. TOP ENGAGED PREDICTORS --- %>
  <div class="mb-16">
    <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#2d5a43]">Top Predictors</h2>
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
      <% @top_predictors.each do |user| %>
        <div class="bg-white border border-slate-100 p-6 rounded-xl shadow-sm">
          <div class="font-black truncate mb-1 uppercase text-[12px] text-[#0a1d13]"><%= user.name %></div>
          <div class="text-3xl font-black text-[#2d5a43] tracking-tighter"><%= user.predictions_count %></div>
          <div class="text-[10px] text-slate-400 uppercase tracking-widest font-bold">Total Predictions</div>
        </div>
      <% end %>
    </div>
  </div>

  <%# --- 04. ACTIVITY METRICS OVERVIEW --- %>
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-12">

    <%# COL 1: SIGNUPS %>
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#0a1d13]">Latest Sign-ups</h2>
      <div class="space-y-1">
        <% @latest_users.each do |user| %>
          <div class="flex justify-between items-center py-2.5 border-b border-slate-100">
            <span class="font-bold truncate max-w-[180px]"><%= user.name %></span>
            <span class="text-slate-400 text-[11px]"><%= time_ago_in_words(user.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    </div>

    <%# COL 2: LIVE VISITS %>
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#0a1d13]">Latest Visits</h2>
      <div class="space-y-1">
        <% @latest_visits.each do |visit| %>
          <% if visit.user.present? %>
            <div class="flex justify-between items-center py-2.5 border-b border-slate-100">
              <span class="font-bold truncate max-w-[180px]"><%= visit.user.name %></span>
              <span class="text-slate-400 text-[11px]"><%= time_ago_in_words(visit.created_at) %> ago</span>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# COL 3: LEAGUES EXPANSION %>
    <div>
      <h2 class="font-black uppercase mb-4 border-b border-[#0a1d13] pb-2 text-[#0a1d13]">Latest Leagues</h2>
      <div class="space-y-1">
        <% @latest_leagues.each do |league| %>
          <div class="flex justify-between items-center py-2.5 border-b border-slate-100">
            <span class="font-bold uppercase truncate max-w-[180px]"><%= league.name %></span>
            <span class="text-slate-400 text-[11px] font-bold"><%= league.users.count rescue 0 %> members</span>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <footer class="mt-32 pt-8 border-t border-slate-200/60 text-center opacity-30 italic">
    End of dashboard.
  </footer>
</div>
